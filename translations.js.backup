    'guida.f5.step2.p': '<strong>Double-tap</strong> (desktop) or <strong>long press</strong> (600ms, Android) on an image. It is added directly without the [+] button.',
    'guida.f5.step3.h': 'Tables: long press on the table',
    'guida.f5.step3.p': '<strong>Long press</strong> (600ms) on a table cell. The entire table is collected as a chunk.',
    'guida.f5.step4.h': 'Export JSON',
    'guida.f5.step4.p': 'Click <strong>Export JSON</strong> in the Collection toolbar. A JSON file with all chunks is downloaded. Import it later to rebuild your document.',
