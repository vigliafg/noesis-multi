    // GUIDA
    'guida.meta.desc': 'Dal primo avvio al primo documento di studio — workflow completo di Noesis in 5 minuti.',
    'guida.hero.badge': 'Manuale d\'uso · Guida Rapida',
    'guida.hero.h1': 'Da zero al primo <em>documento di studio</em>',
    'guida.hero.p': 'Tutto il workflow di Noesis in sequenza logica — dalla libreria all\'export, con le funzioni aggiornate v810.',
    'guida.flow.label': 'Il flusso completo',
    'guida.flow.h2': 'Come funziona <em>Noesis</em>',
    'guida.flow.p': 'Ogni fase si connette alla successiva. Puoi entrare e uscire dal flusso in qualsiasi punto — la libreria gerarchica ti permette di riprendere da dove avevi lasciato.',
    'guida.f1.label': 'Fase 1',
    'guida.f1.h2': '📚 Libreria <em>gerarchica</em>',
    'guida.f1.p': 'Il punto di ingresso dell\'app. Mostra libri, capitoli estratti e snapshot in una vista dark editoriale.',
    'guida.f1.step1.h': 'Importa il primo libro',
    'guida.f1.step1.p': 'Clicca <strong>+ Add Book</strong> nella barra superiore. Seleziona un file <code>.epub</code> dal tuo dispositivo. Il libro viene salvato in IndexedDB (EpubLibraryDB) e appare immediatamente nella lista.',
    'guida.f1.step2.h': 'Apri un libro nel Reader',
    'guida.f1.step2.p': 'Clicca sulla <strong>copertina</strong> del libro. Il reader ripristina automaticamente l\'ultima posizione di lettura salvata.',
    'guida.f1.step3.h': 'Accedi ai capitoli estratti',
    'guida.f1.step3.p': 'Per ogni libro, la libreria mostra i <strong>capitoli estratti</strong> con i loro snapshot. Clicca sul nome di un capitolo per aprire lo snapshot più recente. Clicca sul nome di uno snapshot specifico per aprire quella versione.',
    'guida.img.library': 'Libreria gerarchica Noesis',
    'guida.img.library.caption': '📚 Libreria gerarchica — ogni libro mostra capitoli estratti e snapshot salvati',
    'guida.img.toolbar': 'Toolbar Library con pulsanti Add Book, Import Snapshots, Open Editor e Tools',
    'guida.img.toolbar.caption': '🛠️ Toolbar Library — Add Book, Import Snapshots, Open Editor e dropdown Tools (Pandoc, PDF Viewer)',
    'guida.f2.label': 'Fase 2',
    'guida.f2.h2': '📖 Leggere <em>e annotare</em>',
    'guida.f2.p': 'L\'ambiente principale di lettura con TOC gerarchico, traduzione e highlighting.',
    'guida.card.sidebar.h': 'Sidebar TOC',
    'guida.card.sidebar.p': 'Clicca il pulsante Sidebar per aprire l\'indice gerarchico espandibile. Clicca un capitolo per navigarci direttamente.',
    'guida.card.translation.h': 'Traduzione browser',
    'guida.card.translation.p': 'Click destro sulla pagina → <em>Traduci in italiano</em>. Il browser traduce l\'intero capitolo senza API esterne.',
    'guida.card.highlight.h': 'Highlighting',
    'guida.card.highlight.p': 'Seleziona il testo, poi scegli il colore nel dropdown Highlight: <strong>Giallo</strong> (concetti), <strong>Verde</strong> (esempi), <strong>Rosa</strong> (termini/nomi).',
    'guida.card.savestate.h': 'Save State',
    'guida.card.savestate.p': 'Clicca <strong>Save State</strong> per salvare posizione + tutte le preferenze associate a quel libro.',
    'guida.callout.multilingual': '<strong>Workflow multilingue</strong>Attiva la traduzione browser prima di leggere un testo straniero. Gli highlights rimangono sul testo originale, non sulla traduzione.',
    'guida.f3.label': 'Fase 3',
    'guida.f3.h2': '✏️ Estrarre e <em>scrivere</em>',
    'guida.f3.p': 'Un click su Extract Chapter apre direttamente <strong>Noesis Editor</strong> — l\'editor Summernote unificato con il contenuto del capitolo già caricato.',
    'guida.f3.step1.h': 'Naviga al capitolo desiderato',
    'guida.f3.step1.p': 'Usa la sidebar TOC o le frecce di navigazione per arrivare al capitolo che vuoi estrarre.',
    'guida.f3.step2.h': 'Clicca Extract Chapter',
    'guida.f3.step2.p': 'Il dropdown offre due opzioni: <strong>Solo capitolo corrente</strong> (focalizzato) oppure <strong>Corrente + tutti i sottolivelli</strong> (intera sezione gerarchica assemblata automaticamente).',
    'guida.f3.step3.h': 'Noesis Editor si apre in un nuovo tab',
    'guida.f3.step3.p': 'L\'editor Summernote si apre con tutte le immagini inline (base64) e il contenuto già caricato. Puoi subito evidenziare, raccogliere chunk, salvare snapshot e modificare il testo — tutto nello stesso ambiente. Il capitolo viene registrato in <code>noesisLibraryDB</code>.',
    'guida.f4.label': 'Fase 4',
    'guida.f4.h2': '📸 Versioning <em>a snapshot</em>',
    'guida.f4.p': 'Una delle funzioni più potenti della v810. Il sistema Snapshot crea un backup permanente del tuo lavoro in formato HTML sul filesystem locale.',
    'guida.f4.step1.h': 'Clicca Save (pulsante verde) nella bottoniera Chapter',
    'guida.f4.step1.p': 'Il pulsante verde <strong>Save</strong> nella bottoniera inferiore Chapter apre un prompt che mostra il nome file proposto.',
    'guida.f4.step2.h': 'Opzionale: aggiungi un\'etichetta',
    'guida.f4.step2.p': 'Il prompt permette di aggiungere un\'etichetta personalizzata al nome file. Esempi: <em>"primaLettura"</em>, <em>"dopoChunk"</em>, <em>"versioneFinale"</em>.',
    'guida.f4.step3.h': 'Vengono generati due file',
    'guida.f4.step3.p': 'Noesis produce due file HTML simultaneamente: <strong>_clean</strong> (senza colori highlight) e <strong>_annot</strong> (con tutti gli highlight). Entrambi vengono scaricati e salvati anche in IndexedDB. Appare un toast di conferma.',
    'guida.callout.snapshot': '<strong>Best practice snapshot</strong> — Salva uno snapshot <em>prima</em> di fare modifiche importanti. Così puoi sempre tornare a una versione precedente. La libreria mostra la cronologia completa delle versioni di ogni capitolo.',
    'guida.f5.label': 'Fase 5',
    'guida.f5.h2': '📦 Collezioni di <em>chunk</em>',
    'guida.f5.p': 'Mentre lavori sul capitolo estratto, puoi raccogliere frammenti — detti chunk — per assemblare il documento finale.',
    'guida.f5.step1.h': 'Testo: seleziona e clicca [+]',
    'guida.f5.step1.p': 'Seleziona il testo nell\'editor. Clicca il pulsante <strong>[+]</strong> nella sezione Collection della toolbar. Un toast conferma l\'aggiunta.',
    'guida.f5.step2.h': 'Immagini: doppio tap o long press',
    'guida.f5.step2.p': '<strong>Doppio tap</strong> (desktop) o <strong>long press</strong> (600ms, Android) su un\'immagine. Viene aggiunta direttamente senza il pulsante [+].',
    'guida.f5.step3.h': 'Tabelle: long press sulla tabella',
    'guida.f5.step3.p': '<strong>Long press</strong> (600ms) su una cella della tabella. L\'intera tabella viene raccolta come chunk.',
    'guida.f5.step4.h': 'Export JSON',
    'guida.f5.step4.p': 'Clicca <strong>Export JSON</strong> nella toolbar Collection. Viene scaricato un file JSON con tutti i chunk. Importalo in seguito per ricostruire il documento.',
    'guida.img.collection': 'Noesis Editor — pannello inspect collezione con chunk raccolti',
    'guida.img.collection.caption': '📦 Collection Inspect — lista chunk raccolti con anteprima, selezione ed eliminazione',
    'guida.f6.label': 'Fase 6',
    'guida.f6.h2': '📤 Esporta e <em>condividi</em>',
    'guida.f6.p': 'Noesis Editor supporta più formati di export per tutti i casi d\'uso.',
    'guida.export.pdf.h': 'PDF',
    'guida.export.pdf.p': 'Apre il dialog di stampa del browser con il capitolo formattato per la stampa. Per rendering avanzato, usa PDF.js Viewer dal Tools della Library.',
    'guida.export.docx.h': 'DOCX',
    'guida.export.docx.p': 'Documento Word con formattazione completa. Compatibile con LibreOffice, Google Docs e Microsoft Word.',
    'guida.export.md.h': 'Markdown',
    'guida.export.md.p': 'Formato Markdown con o senza immagini in ZIP. Ideale per blog statici, GitHub o documentazione.',
    'guida.export.html.h': 'HTML per CMS',
    'guida.export.html.p': 'Copia l\'HTML completo negli appunti. Incollalo direttamente in WordPress, Ghost o Webflow.',
    'guida.img.exportmenu': 'Menu export Noesis Editor',
    'guida.img.exportmenu.caption': '📤 Menu export — PDF, DOCX, Markdown, MD+ZIP, HTML, TXT, JSON',
    'guida.tips.label': 'Tips & Tricks',
    'guida.tips.h2': 'Ottieni il <em>massimo</em> da Noesis',
    'guida.tip1.h': 'Usa un server locale',
    'guida.tip1.p': 'Per EPUB con risorse complesse, avvia un server locale: <code>python -m http.server 8000</code>. Evita le restrizioni CORS con il protocollo <code>file://</code>.',
    'guida.tip2.h': 'Salva snapshot spesso',
    'guida.tip2.p': 'Prima di qualsiasi operazione di editing importante, salva uno snapshot. Richiede 2 secondi e protegge dalla perdita accidentale del lavoro.',
    'guida.tip3.h': 'Riduci gli EPUB grandi',
    'guida.tip3.p': 'Se un EPUB ha troppe immagini, usa ePub Slimmer prima di importarlo. Riduce significativamente i tempi di caricamento e lo spazio in IndexedDB.',
    'guida.tip4.h': 'Android: usa Chrome',
    'guida.tip4.p': 'Su Android, Chrome offre la migliore compatibilità con tutte le funzioni di Noesis inclusa la File System Access API per gli snapshot.',
    'guida.f3.link': 'Documentazione Noesis Editor →',
    'guida.f4.link': 'Documentazione completa Snapshot →',
    'guida.profile.label': 'Workflow per profilo',
    'guida.profile.h2': 'Percorsi <em>consigliati</em>',
    'guida.profile.student.btn': '🎓 Studente — Workflow di studio',
    'guida.profile.student.body': '<ol style="padding-left:20px; line-height:2;"><li>Importa il manuale (.epub)</li><li>Naviga al capitolo da studiare (TOC sidebar)</li><li>Leggi + evidenzia: giallo = concetti, verde = esempi, rosa = termini</li><li>Estrai il capitolo (corrente + sottolivelli)</li><li>Salva snapshot <em>"Lettura base"</em></li><li>Aggiungi selezioni importanti alla collezione</li><li>Salva snapshot <em>"Dopo raccolta chunk"</em></li><li>Apri Noesis Editor → struttura con H1/H2 e liste tramite l\'Inspect Panel</li><li>Esporta in PDF per la consegna</li></ol>',
    'guida.profile.researcher.btn': '🔬 Ricercatore — Workflow approfondito',
    'guida.profile.researcher.body': '<ol style="padding-left:20px; line-height:2;"><li>Importa il paper/monografia (.epub)</li><li>Attiva traduzione browser se in lingua straniera</li><li>Seleziona grafici e immagini → aggiungi alla collezione (base64)</li><li>Seleziona citazioni rilevanti → collezione</li><li>Salva snapshot <em>"Prima revisione"</em></li><li>Esporta la collezione come JSON (backup)</li><li>Continua analisi, aggiungi annotazioni → salva snapshot <em>"Annotazioni complete"</em></li><li>Estrai un capitolo → Noesis Editor si apre con i chunk nell\'Inspect Panel → struttura il report</li><li>Esporta in DOCX per revisione collegiale</li></ol>',
    'guida.profile.blogger.btn': '📝 Blogger/Creator — Workflow veloce',
    'guida.profile.blogger.body': '<ol style="padding-left:20px; line-height:2;"><li>Leggi il libro con Noesis</li><li>Seleziona i passaggi per la review → collezione</li><li>Estrai i capitoli rilevanti</li><li>Salva snapshot <em>"Materiale raccolto"</em></li><li>Estrai il capitolo → Noesis Editor si apre direttamente</li><li>Scrivi la review nell\'editor WYSIWYG</li><li>Copia HTML → incolla nel CMS</li></ol>',
    'guida.profile.multilingual.btn': '🌍 Lettore multilingue — Studio lingua',
    'guida.profile.multilingual.body': '<ol style="padding-left:20px; line-height:2;"><li>Importa romanzo nella lingua target</li><li>Attiva traduzione browser per lingua madre</li><li>Leggi con doppio riferimento (originale + traduzione)</li><li>Highlight parole nuove (rosa)</li><li>Estrai il capitolo → Salva snapshot <em>"Vocabolario sessione 1"</em></li><li>Aggiungi frasi difficili alla collezione</li><li>Esporta collezione JSON → archivio personale</li></ol>',

    // LIBRARY (abbreviated - same as EN keys but IT values)
    'library.meta.desc': 'Noesis Library: gestisci la tua biblioteca EPUB, naviga la gerarchia libri-capitoli-snapshot e accedi al Noesis Editor in modalità standalone.',
    'library.hero.badge': 'Ambiente · Noesis Library',
    'library.hero.h1': 'Noesis Library — <em>la tua biblioteca di conoscenza</em>',
    'library.hero.p': 'Il punto di ingresso di Noesis. Gestisci la tua collezione EPUB, naviga la gerarchia libri → capitoli → snapshot, e accedi al Noesis Editor direttamente dalla libreria.',
    'library.overview.label': 'Panoramica',
    'library.overview.h2': 'Un archivio <em>gerarchico</em>',
    'library.overview.p': 'Noesis Library organizza la tua conoscenza su tre livelli: ogni <strong>libro</strong> mostra i <strong>capitoli estratti</strong>, e ogni capitolo espone i suoi <strong>snapshot</strong> salvati nel tempo — tutto accessibile con un click.',
    'library.card.books.h': 'Libri',
    'library.card.books.p': 'Ogni EPUB importato appare con copertina, titolo, autore e numero di capitoli estratti. Clicca sulla copertina per aprire il libro nel <strong>Noesis Reading</strong>.',
    'library.card.chapters.h': 'Capitoli estratti',
    'library.card.chapters.p': 'Sotto ogni libro compaiono i capitoli che hai estratto. Clicca sul nome del capitolo per aprire lo snapshot più recente direttamente nel <strong>Noesis Editor</strong>.',
    'library.card.snapshots.h': 'Snapshot',
    'library.card.snapshots.p': 'Ogni capitolo mostra i suoi snapshot con nome, variante (annotated / clean / origin) e data di salvataggio. Clicca su uno snapshot specifico per aprire quella versione esatta nell\'editor.',
    'library.img.library': 'Noesis Library — gerarchia libri, capitoli estratti e snapshot',
    'library.img.library.caption': '📚 Noesis Library — griglia libri con gerarchia capitoli estratti e snapshot versioni',
    'library.toolbar.label': 'Toolbar',
    'library.toolbar.h2': 'La bottoniera della <em>Library</em>',
    'library.toolbar.p': 'La toolbar in alto a destra raccoglie tutti i comandi globali della libreria.',
    'library.img.toolbar': 'Bottoniera Library',
    'library.img.toolbar.caption': 'Bottoniera della Library',
    'library.btn.addbook.h': 'ADD BOOK',
    'library.btn.addbook.p': 'Apre il file picker del browser. Seleziona uno o più file <code>.epub</code> dal tuo dispositivo. Il libro viene salvato in <code>noesisLibraryDB</code> (IndexedDB) e appare immediatamente nella griglia.',
    'library.btn.import.h': 'Import Snapshots',
    'library.btn.import.p': 'Importa file snapshot precedentemente salvati su filesystem (file HTML con meta tag Noesis). Il sistema legge il <code>chapterId</code> e il nome del libro incorporati e aggiorna automaticamente la gerarchia.',
    'library.btn.editor.h': 'Open Editor',
    'library.btn.editor.p': 'Apre Noesis Editor in modalità standalone, senza capitolo pre-caricato. Ideale per creare documenti da zero o da una collezione importata via JSON.',
    'library.btn.tools.h': 'Tools ▾',
    'library.btn.tools.p': 'Dropdown con strumenti aggiuntivi: <strong>Pandoc Online</strong> (conversioni documento in-browser via pandoc.wasm) e <strong>PDF.js Viewer</strong> (rendering PDF di alta qualità).',
    'library.books.label': 'Gestione libri',
    'library.books.h2': 'Gestire i <em>libri</em>',
    'library.books.p': 'Ogni card libro nella libreria offre controlli contestuali per gestire il titolo e i contenuti correlati.',
    'library.book.open.h': 'Apri nel Reader',
    'library.book.open.p': 'Clicca ovunque sulla copertina per aprire il libro nel Noesis Reading. Il reader ripristina automaticamente l\'ultimo stato salvato (posizione, tema, dimensione font).',
    'library.book.delete.h': 'Elimina libro',
    'library.book.delete.p': 'Il pulsante rosso ✕ rimuove permanentemente il libro da IndexedDB e tutti i metadati dei capitoli associati da noesisDB. I file snapshot sul filesystem <strong>non</strong> vengono eliminati — restano disponibili per reimportazione futura.',
    'library.book.mozilla.h': 'Compatibilità Firefox',
    'library.book.mozilla.p': 'Su Firefox, la Library è pienamente funzionale. L\'unica differenza è che il dropdown Tools potrebbe non mostrare lo strumento Pandoc Online. Tutte le altre funzionalità — import, reader, editor, snapshot — funzionano in modo identico.',
    'library.img.mozilla': 'Toolbar Library su Firefox',
    'library.img.mozilla.caption': '🦊 Library su Firefox — tutte le funzionalità disponibili, piccole differenze nella toolbar',
    'library.chapters.label': 'Capitoli e snapshot',
    'library.chapters.h2': 'La struttura <em>gerarchica</em>',
    'library.chapters.p': 'La struttura gerarchica sotto ogni card libro dà accesso immediato a tutto il lavoro estratto.',
    'library.ch.variants.h': 'Varianti snapshot',
    'library.ch.variants.p': 'Ogni snapshot salvato genera due varianti: <code>_annot</code> (con i colori highlight preservati) e <code>_clean</code> (versione pulita senza formattazione colori, ideale per lettura o export). Il <code>_origin</code> è lo snapshot salvato automaticamente al momento dell\'estrazione.',
    'library.ch.click.h': 'Navigazione diretta',
    'library.ch.click.p': 'Clicca sul nome del capitolo → apre lo snapshot più recente. Clicca su uno snapshot specifico → apre quella versione esatta nel Noesis Editor. Nessun dialog intermedio.',
    'library.ch.delete.h': 'Eliminare uno snapshot',
    'library.ch.delete.p': 'Ogni riga snapshot ha un pulsante di eliminazione. Rimuovere uno snapshot dalla libreria elimina solo il record di metadati in IndexedDB — il file HTML sul filesystem non viene toccato.',
    'library.btn.theme.h': 'Toggle Theme',
    'library.btn.theme.p': 'Alterna tra il tema chiaro e il tema scuro della Library. La preferenza viene salvata in localStorage e ripristinata al prossimo avvio.',
    'library.btn.help.h': 'Help Overlay',
    'library.btn.help.p': 'Apre un pannello di aiuto contestuale con le istruzioni principali per l\'uso della Library. Visibile anche al primo avvio dell\'applicazione.',
    'library.tools.label': 'Tools',
    'library.tools.h2': 'Strumenti <em>accessori</em>',
    'library.tools.p': 'Il dropdown <strong>Tools ▾</strong> nella toolbar raccoglie gli strumenti di supporto integrati nell\'applicazione.',
    'library.tools.epub.h': 'noesis-epub-tools',
    'library.tools.epub.p': 'Accesso diretto agli helper tools interni: <strong>ePub Slimmer</strong> (compressione singolo file), <strong>Multi ePub Slimmer</strong> (batch fino a 10 file) e <strong>ePub Splitter</strong> (crea EPUB standalone da capitoli selezionati). <a href="helpers.html" style="color:var(--violet);">Documentazione Helper →</a>',
    'library.tools.pandoc.h': 'Pandoc Online',
    'library.tools.pandoc.p': 'Apre Pandoc Online in una nuova tab — convertitore universale di documenti. Utile per trasformare i file esportati dal Noesis Editor in altri formati (LaTeX, RST, ODT, ecc.).',
    'library.tools.pdfjs.h': 'Mozilla PDF Viewer',
    'library.tools.pdfjs.p': 'Apre Mozilla PDF.js in una nuova tab. Permette di visualizzare, cercare e stampare qualsiasi file PDF con rendering ad alta qualità, senza lasciare l\'ecosistema Noesis.',
    'library.tools.img': 'Noesis Library — dropdown Tools aperto con le tre opzioni',
    'library.tools.img.caption': '🛠️ Tools dropdown — noesis-epub-tools, Pandoc Online, Mozilla PDF Viewer',
    'library.standalone.label': 'Noesis Editor',
    'library.standalone.h2': 'Apri l\'editor in modalità <em>standalone</em>',
    'library.standalone.p': 'Non hai bisogno di estrarre un capitolo per usare il Noesis Editor. Il pulsante <strong>Open Editor</strong> nella toolbar avvia l\'editor in modalità standalone — un documento vuoto pronto per qualsiasi contenuto.',
    'library.standalone.mode.h': 'Modalità standalone',
    'library.standalone.mode.p': 'Editor vuoto con tutta la toolbar disponibile. Puoi scrivere, formattare, inserire tabelle e immagini, e usare Excalidraw esattamente come in modalità <em>chapter</em>.',
    'library.standalone.chunks.h': 'Import chunk dalla collezione',
    'library.standalone.chunks.p': 'Anche in modalità standalone, l\'Inspect Panel della collezione è disponibile. Puoi iniettare chunk raccolti durante sessioni di lettura precedenti nel documento corrente.',
    'library.standalone.callout': '<strong>Editor sempre in una nuova tab</strong> — Il Noesis Editor si apre sempre in un tab separato del browser, sia dalla Library (standalone) sia dal Noesis Reading (chapter). Puoi avere Library, Reading e Editor aperti contemporaneamente.',
    'library.standalone.link': 'Documentazione Noesis Editor →',

    // READING (abbreviated)
    'reading.meta.desc': 'Noesis Reading: leggi EPUB, annota con highlighting a 3 colori, gestisci segnalibri, personalizza temi e tipografia, ed estrai capitoli nel Noesis Editor.',
    'reading.hero.badge': 'Ambiente · Noesis Reading',
    'reading.hero.h1': 'Noesis Reading — <em>leggi, annota, estrai</em>',
    'reading.hero.p': 'L\'ambiente di lettura EPUB con TOC gerarchica, 15 temi, highlighting a 3 colori, segnalibri e estrazione capitoli diretta nel Noesis Editor.',
    'reading.toolbar.label': 'Toolbar',
    'reading.toolbar.h2': 'La bottoniera del <em>Reader</em>',
    'reading.toolbar.p': 'La toolbar del Noesis Reading raccoglie tutti gli strumenti di lettura e annotazione. È sempre visibile in cima allo schermo.',
    'reading.img.buttons': 'Bottoniera Noesis Reading',
    'reading.img.buttons.caption': '← Library · Sidebar · Segnalibri · Highlight (giallo) · Display · Scroll · % · Save State (arancio) · Extract Chapter (verde) · ?',
    'reading.btn.library.h': '← Library',
    'reading.btn.library.p': 'Torna alla Noesis Library senza perdere lo stato del libro corrente. La posizione viene ripristinata alla prossima apertura tramite Save State.',
    'reading.btn.sidebar.h': 'Sidebar',
    'reading.btn.sidebar.p': 'Apre/chiude il TOC gerarchico espandibile. Supporta fino a 3 livelli di annidamento. Clicca una voce per navigare direttamente a quella sezione.',
    'reading.btn.bookmarks.h': 'Segnalibri',
    'reading.btn.bookmarks.p': 'Apre il pannello segnalibri. Aggiungi un segnalibro personalizzato per la posizione corrente con titolo e data. Salvati in <code>localStorage</code>.',
    'reading.btn.highlight.h': 'Highlight',
    'reading.btn.highlight.p': 'Dropdown con 3 colori: <strong>Giallo</strong> (concetti generali), <strong>Verde</strong> (esempi/punti chiave), <strong>Rosa</strong> (termini/nomi). Anche: rimuovi tutti gli highlight. Gli highlight sono CFI-based e sopravvivono al ricaricamento della pagina.',
    'reading.btn.display.h': 'Display Settings',
    'reading.btn.display.p': 'Pannello accordion unificato con: 15 temi di lettura in 5 gruppi, dimensione font, altezza riga, larghezza pagina, famiglia font, color picker sfondo e testo.',
    'reading.btn.scroll.h': 'Modalità scroll',
    'reading.btn.scroll.p': 'Alterna tra modalità paginata e scorrimento continuo. In modalità paginata, usa i tasti freccia o swipe per girare pagina.',
    'reading.btn.percent.h': '% Progresso',
    'reading.btn.percent.p': 'Mostra il progresso di lettura corrente in percentuale. Clicca per saltare a una percentuale specifica del libro.',
    'reading.btn.savestate.h': 'Save State',
    'reading.btn.savestate.p': 'Salva lo stato corrente: posizione nel capitolo, tutte le impostazioni display (tema, font, dimensione, colori). Lo stato viene ripristinato automaticamente alla riapertura del libro dalla libreria.',
    'reading.btn.extract.h': 'Extract Chapter',
    'reading.btn.extract.p': 'Pulsante principale di estrazione. Dropdown con due opzioni: solo capitolo corrente, o corrente + tutti i sottolivelli. Apre Noesis Editor in un nuovo tab con il contenuto già caricato.',
    'reading.modes.label': 'Modalità di Lettura',
    'reading.modes.h2': 'Tre modi di <em>leggere</em>',
    'reading.modes.p': 'Scegli la modalità più adatta al tuo dispositivo e al tuo stile. Puoi cambiarla in qualsiasi momento con il pulsante Scroll nella toolbar.',
    'reading.modes.single.h': 'Pagina Singola',
    'reading.modes.single.p': 'Una pagina alla volta con navigazione tramite frecce laterali. Ideale per schermi piccoli, tablet e lettura concentrata.',
    'reading.modes.double.h': 'Doppia Pagina',
    'reading.modes.double.p': 'Due pagine affiancate che simulano un libro aperto. Ottimale per schermi larghi (>1024px). Si attiva automaticamente in base alla larghezza della finestra.',
    'reading.modes.scroll.h': 'Scroll Continuo',
    'reading.modes.scroll.p': 'Flusso verticale senza interruzioni. Ideale per lettura immersiva e scorrimento rapido. I pulsanti freccia vengono nascosti automaticamente.',
    'reading.toc.label': 'Sidebar TOC',
    'reading.toc.h2': 'Indice <em>gerarchico</em>',
    'reading.toc.p': 'La sidebar mostra la Table of Contents del libro con struttura ad albero espandibile fino a 3 livelli di profondità.',
    'reading.toc.nav.h': 'Navigazione capitoli',
    'reading.toc.nav.p': 'Clicca su qualsiasi voce dell\'indice per navigare direttamente a quel capitolo. La posizione si aggiorna in tempo reale.',
    'reading.toc.expand.h': 'Espandi / Comprimi',
    'reading.toc.expand.p': '<strong>▸</strong> = nodo espandibile, <strong>▾</strong> = nodo espanso, <strong>•</strong> = foglia (nessun sottolivello).',
    'reading.toc.depth.h': 'Profondità gerarchica',
    'reading.toc.depth.p': 'Supporta strutture TOC annidate fino a 3 livelli — capitoli, sotto-capitoli e sezioni specifiche tutte navigabili.',
    'reading.toc.empty.h': 'EPUB senza TOC',
    'reading.toc.empty.p': 'Se la sidebar è vuota, il libro non ha un indice definito. Puoi comunque navigare con le frecce o in scroll continuo.',
    'reading.nav.label': 'Navigazione',
    'reading.nav.h2': 'Pulsanti <em>flottanti</em>',
    'reading.nav.left.h': 'Freccia Sinistra',
    'reading.nav.left.p': 'Pagina o capitolo precedente. Si nasconde in modalità scroll e al primo capitolo del libro.',
    'reading.nav.right.h': 'Freccia Destra',
    'reading.nav.right.p': 'Pagina o capitolo successivo. Appare come pulsante circolare sul lato destro dello schermo.',
    'reading.nav.click.h': 'Click laterale',
    'reading.nav.click.p': 'In modalità paginata: click sulla metà sinistra torna indietro, click sulla metà destra avanza. Alternativa rapida ai pulsanti.',
    'reading.display.label': 'Display Settings',
    'reading.display.h2': 'Tipografia, temi e interfaccia <em>in un pannello</em>',
    'reading.display.p': 'Il pulsante <strong>Display</strong> apre un pannello accordion unificato che raccoglie tutti i controlli di visualizzazione: tipografia, temi di lettura e colori interfaccia.',
    'reading.display.fontsize.h': 'Font Size',
    'reading.display.fontsize.p': 'Pulsanti <strong>A−</strong> e <strong>A+</strong> per ridurre o aumentare il testo. Range: 50%–200% della dimensione base dell\'EPUB.',
    'reading.display.lineheight.h': 'Line Height',
    'reading.display.lineheight.p': 'Pulsanti <strong>≡−</strong> e <strong>≡+</strong> per l\'interlinea. Range: 1.0–1.8. Un\'interlinea più ampia migliora la leggibilità su testi densi.',
    'reading.display.single.h': 'Pagina Singola',
    'reading.display.single.p': 'Forza la visualizzazione a colonna singola indipendentemente dalla larghezza dello schermo.',
    'reading.display.double.h': 'Doppia Pagina',
    'reading.display.double.p': 'Forza la visualizzazione a due colonne affiancate simulando un libro aperto.',
    'reading.display.img': 'Noesis Reading — modalità doppia pagina con pannello Display aperto',
    'reading.display.img.caption': '👁 Display Settings — tipografia, layout pagina nel pannello accordion',
    'reading.display.tip': '<strong>Preferenze per libro</strong> — Le impostazioni tipografiche vengono salvate per ogni libro singolarmente tramite il pulsante <strong>Save State</strong>. Ogni EPUB ricorda la propria configurazione.',
    'reading.themegroup.warm': 'Caldi',
    'reading.themegroup.lightgray': 'Grigi chiari',
    'reading.themegroup.darkgray': 'Grigi scuri',
    'reading.themegroup.night': 'Notturni',
    'reading.themes.callout': '<strong>True Black per OLED</strong> — Il tema True Black usa sfondo nero assoluto (#000000) — ideale per schermi OLED/AMOLED perché i pixel spenti non consumano energia.',
    'reading.interface.label': 'Display Settings — Interfaccia',
    'reading.interface.h2': 'Impostazioni <em>interfaccia</em>',
    'reading.interface.p': 'La sezione Interfaccia nel pannello <strong>Display Settings</strong> personalizza i colori di tutti gli elementi dell\'interfaccia e la loro opacità.',
    'reading.interface.toolbar.h': 'Toolbar Color',
    'reading.interface.toolbar.p': 'Colore di sfondo della toolbar principale del reader.',
    'reading.interface.sidebar.h': 'Sidebar Color',
    'reading.interface.sidebar.p': 'Colore di sfondo della sidebar TOC. Può essere diverso dalla toolbar per distinguere le due aree.',
    'reading.interface.navbtn.h': 'Nav Buttons Color',
    'reading.interface.navbtn.p': 'Colore dei pulsanti di navigazione flottanti (◀ ▶).',
    'reading.interface.opacity.h': 'Nav Opacity',
    'reading.interface.opacity.p': 'Slider 0–100%: regola l\'opacità di toolbar e controlli. Riducila per un\'esperienza più immersiva.',
    'reading.hl.none.h': 'Nessuno / Rimuovi',
    'reading.hl.none.p': 'Disattiva l\'highlight attivo. Seleziona "Nessuno" e clicca su testo evidenziato per rimuovere il colore.',
    'reading.highlight.callout': '<strong>Gli highlight del reader rimangono nel reader</strong> — Il Noesis Editor ha un proprio sistema di highlighting inline basato su Summernote. I due sistemi sono indipendenti e operano sulle rispettive interfacce.',
    'reading.bookmark.create.h': 'Crea un segnalibro',
    'reading.bookmark.create.p': 'Clicca il pulsante <strong>🔖 Segnalibri</strong> nella toolbar → si apre il pannello My Bookmarks → clicca <strong>New Bookmark</strong>. Il segnalibro salva la posizione CFI esatta del cursore nel testo.',
    'reading.bookmark.panel.h': 'Pannello My Bookmarks',
    'reading.bookmark.panel.p': 'Lista di tutti i segnalibri per il libro corrente, ordinati per data di creazione. Ogni voce mostra titolo, anteprima del testo circostante e data.',
    'reading.bookmark.goto.h': 'Torna a un segnalibro',
    'reading.bookmark.goto.p': 'Clicca su qualsiasi segnalibro nel pannello per navigare direttamente a quella posizione nel testo.',
    'reading.bookmark.del.h': 'Elimina un segnalibro',
    'reading.bookmark.del.p': 'Clicca la X accanto al segnalibro per rimuoverlo. La rimozione è immediata e aggiorna il badge del pulsante.',
    'reading.savestate.label': 'Persistenza',
    'reading.savestate.h2': 'Save State — <em>salva tutto</em>',
    'reading.savestate.p': 'Il pulsante <strong>💾 Save State</strong> salva manualmente la posizione di lettura corrente e tutte le preferenze associate al libro specifico.',
    'reading.savestate.what.h': 'Cosa viene salvato',
    'reading.savestate.what.p': 'Posizione CFI esatta nel testo, font size, line height, modalità pagina (singola/doppia), tema di lettura, colori interfaccia e modalità scroll.',
    'reading.savestate.perbook.h': 'Per ogni libro',
    'reading.savestate.perbook.p': 'Le preferenze vengono salvate per libro singolarmente in <code>noesisLibraryDB</code>. Ogni EPUB ricorda la propria configurazione indipendentemente dagli altri.',
    'reading.savestate.callout': '<strong>Ripristino automatico</strong> — Quando riapri un libro dalla Noesis Library, la posizione e le preferenze vengono ripristinate automaticamente all\'ultimo stato salvato.',
    'reading.savestate.table.key': 'Chiave localStorage',
    'reading.savestate.table.content': 'Contenuto',
    'reading.savestate.table.scope': 'Scope',
    'reading.savestate.scope.global': 'Globale',
    'reading.savestate.scope.perbook': 'Per libro',
    'reading.extract.single.h': 'Solo il capitolo corrente',
    'reading.extract.single.p': 'Estrae unicamente il capitolo visualizzato nel reader. Documento focalizzato, ideale per annotazione di una singola sezione.',
    'reading.extract.deep.h': 'Corrente + tutti i sottolivelli',
    'reading.extract.deep.p': 'Estrae il capitolo corrente più tutti i sotto-capitoli annidati, assemblati nell\'ordine della spine EPUB. Ideale per sezioni ampie.',
    'reading.extract.callout': '<strong>Estrazione diretta</strong> — Il capitolo si apre direttamente nel Noesis Editor in un nuovo tab. Tutte le immagini vengono convertite in base64 inline — il documento è completamente autocontenuto.',
    'reading.extract.link': 'Documentazione Noesis Editor →',
    'reading.pagenav.prev': '← Noesis Library',
    'reading.pagenav.next': 'Noesis Editor →',
    'reading.img.toc': 'Noesis Reading sidebar TOC — indice gerarchico',
    'reading.img.toc.caption': '☰ Sidebar TOC gerarchica — espandibile fino a 3 livelli con navigazione diretta',
    'reading.themes.label': 'Temi di Lettura',
    'reading.themes.h2': '15 temi in <em>5 gruppi</em>',
    'reading.themes.p': 'Il pannello Display Settings offre 15 temi predefiniti organizzati in 5 gruppi per luminosità. Puoi anche personalizzare i colori sfondo e testo direttamente con i picker.',
    'reading.themegroup.light': 'Chiari',
    'reading.themegroup.gray': 'Grigi',
    'reading.themegroup.dark': 'Scuri',
    'reading.img.themes': 'Selezione tema di lettura — 15 temi in 5 gruppi',
    'reading.img.themes.caption': '🎨 Pannello display — 15 temi in 5 gruppi, tipografia personalizzabile',
    'reading.highlight.label': 'Highlighting',
    'reading.highlight.h2': 'Sistema di <em>annotazione</em> a 3 colori',
    'reading.highlight.p': 'Gli highlight vengono salvati in <code>localStorage</code> usando CFI (Canonical Fragment Identifiers) — un sistema standardizzato per riferire posizioni negli EPUB. Sopravvivono al ricaricamento della pagina e alla riapertura del libro.',
    'reading.hl.yellow.h': 'Giallo — Concetti generali',
    'reading.hl.yellow.p': 'Ideale per passaggi chiave, argomenti principali, definizioni.',
    'reading.hl.green.h': 'Verde — Esempi e punti chiave',
    'reading.hl.green.p': 'Per esempi pratici, dati importanti, evidenze empiriche.',
    'reading.hl.pink.h': 'Rosa — Termini e nomi',
    'reading.hl.pink.p': 'Per termini tecnici, nomi propri, entità da ricordare.',
    'reading.img.highlight': 'Noesis Reader — highlighting a 3 colori attivo sul testo',
    'reading.img.highlight.caption': '🎨 Sistema highlight a 3 colori — giallo, verde e rosa con rimozione selettiva',
    'reading.bookmark.label': 'Segnalibri',
    'reading.bookmark.h2': 'Segnalibri <em>personalizzati</em>',
    'reading.bookmark.p': 'Il sistema segnalibri permette di salvare posizioni precise in qualsiasi libro con un nome personalizzato. I segnalibri vengono salvati in <code>localStorage</code> e persistono tra le sessioni.',
    'reading.img.bookmark': 'Noesis Reader — pannello segnalibri personalizzati',
    'reading.img.bookmark.caption': '🔖 Pannello segnalibri — aggiungi, naviga ed elimina segnalibri personalizzati',
    'reading.extract.label': 'Estrazione Capitoli',
    'reading.extract.h2': 'Due modalità di <em>estrazione</em>',
    'reading.extract.p': 'Il pulsante Extract Chapter nella toolbar apre un dropdown con due opzioni per adattarsi alla struttura dei capitoli del libro.',
    'reading.img.extract': 'Menu Extract Chapter — capitolo corrente e corrente + sottolivelli',
    'reading.img.extract.caption': '📥 Extract Chapter — dropdown con le due modalità di estrazione nel reader',
    'reading.storage.label': 'Storage locale',
    'reading.storage.h2': 'Dove vengono salvati i <em>dati</em>',
    'reading.storage.p': 'Noesis Reading salva tutti i dati in storage locale del browser — nessun dato lascia il dispositivo.',

    // EDITOR (abbreviated)
    'editor.meta.desc': 'Noesis Editor: estrazione capitoli EPUB, highlighting, snapshot e WYSIWYG Summernote in un unico ambiente. Export PDF, DOCX, Markdown, HTML.',
    'editor.hero.badge': 'Ambiente · Noesis Editor',
    'editor.hero.h1': 'Noesis Editor — <em>estrai, annota e scrivi</em>',
    'editor.hero.p': 'Dal click su Extract Chapter nel Noesis Reading si apre direttamente il <strong>Noesis Summernote Editor</strong>: un unico ambiente per leggere il capitolo estratto, evidenziare, gestire snapshot, raccogliere chunk e costruire il tuo documento.',
    'editor.extract.label': 'Estrazione Capitoli',
    'editor.extract.h2': 'Due modalità, <em>un click</em>',
    'editor.extract.p': 'Il pulsante Extract Chapter nella toolbar del reader apre un dropdown con due opzioni. Noesis legge la gerarchia TOC del libro e assembla automaticamente il documento, che si apre direttamente nel Noesis Editor.',
    'editor.card.single.h': 'Solo il capitolo corrente',
    'editor.card.single.p': 'Estrae unicamente il capitolo visualizzato nel reader. Documento focalizzato, ideale per lettura rapida, traduzione mirata o annotazione di una singola sezione.',
    'editor.card.branch.h': 'Corrente + tutti i sottolivelli',
    'editor.card.branch.p': 'Estrae il capitolo corrente più <strong>tutti i sotto-capitoli annidati</strong>, assemblati nell\'ordine della spine EPUB in un unico documento. Ideale per sezioni ampie o intere parti di un saggio.',
    'editor.img.extract': 'Dropdown Extract Chapter',
    'editor.img.extract.caption': '📥 Extract Chapter — dropdown con le due modalità di estrazione nel reader',
    'editor.how.label': 'Come funziona',
    'editor.how.h2': 'Il processo di <em>estrazione</em>',
    'editor.how.step1.h': 'Parsing della struttura TOC',
    'editor.how.step1.p': 'Noesis legge il nodo TOC corrente e identifica ricorsivamente tutti i sotto-nodi figli. Per l\'estrazione gerarchica, viene costruita la lista completa dei file EPUB da assemblare.',
    'editor.how.step2.h': 'Caricamento e conversione immagini',
    'editor.how.step2.p': 'Per ogni capitolo estratto, Noesis accede ai file immagine dentro l\'EPUB tramite JSZip, li converte in <strong>base64 inline</strong> e li incorpora direttamente nel documento. Il risultato è un HTML completamente autocontenuto senza dipendenze esterne.',
    'editor.how.step3.h': 'Generazione payload e apertura editor',
    'editor.how.step3.p': 'Il contenuto HTML viene iniettato in un payload JSON insieme a <code>bookName</code>, <code>chapterId</code> e modalità <code>chapter</code>. Il Noesis Editor si apre in un nuovo tab via Blob URL con il contenuto già caricato.',
    'editor.toolbar.label': 'Toolbar',
    'editor.toolbar.h2': 'La bottoniera dell\'<em>Editor</em>',
    'editor.toolbar.p': 'Il Noesis Editor ha una toolbar strutturata nella parte bassa dello schermo, divisa in tre sezioni: Chapter, Collection e Tools.',
    'editor.img.toolbar': 'Toolbar principale Noesis Editor',
    'editor.img.toolbar.caption': 'CHAPTER: nuovo · apri · salva snapshot · opzioni | COLLECTION: aggiungi · esporta · importa · opzioni · anteprima · elimina | TOOLS',
    'editor.chapter.label': 'Sezione Chapter',
    'editor.chapter.h2': 'Gestione del <em>capitolo</em>',
    'editor.chapter.p': 'La sezione Chapter della toolbar gestisce il capitolo corrente — salvataggio snapshot, apertura nuovi e configurazione delle opzioni di estrazione.',
    'editor.chapter.new.h': 'New',
    'editor.chapter.new.p': 'Azzera l\'editor in-place — svuota l\'area di contenuto per un nuovo documento. Non perde il capitolo corrente in noesisDB.',
    'editor.chapter.open.h': 'Open',
    'editor.chapter.open.p': 'Apre un file picker per caricare un file HTML esistente direttamente nell\'editor. Utile per riaprire uno snapshot salvato su filesystem.',
    'editor.chapter.save.h': 'Save Snapshot',
    'editor.chapter.save.p': 'L\'operazione snapshot principale. Genera due file simultaneamente: <code>_clean.html</code> (senza colori highlight) e <code>_annot.html</code> (con tutti gli highlight). Entrambi vengono scaricati e registrati in <code>noesisDB</code>.',
    'editor.img.snapshots': 'Noesis Editor — pannello Import Snapshots con cronologia snapshot',
    'editor.img.snapshots.caption': '📸 Import Snapshots — cronologia versioni salvate con opzioni carica ed elimina',
    'editor.excalidraw.label': 'Excalidraw',
    'editor.excalidraw.h2': 'Diagrammi <em>integrati</em>',
    'editor.excalidraw.p': 'Noesis Editor integra Excalidraw in una tab dedicata. Crea diagrammi, flowchart e mappe mentali visivamente, poi esporta direttamente nel documento.',
    'editor.img.excalidraw': 'Noesis Editor — Excalidraw integrato in tab dedicata',
    'editor.img.excalidraw.caption': '✏️ Excalidraw — creazione diagrammi, flowchart e mappe mentali integrata nel Noesis Editor',
    'editor.collection.label': 'Collection',
    'editor.collection.h2': 'Il sistema <em>chunk</em>',
    'editor.collection.p': 'La sezione Collection permette di raccogliere frammenti di contenuto — chunk — mentre si lavora sul capitolo estratto.',
    'editor.collection.add.h': '[+] Aggiungi chunk',
    'editor.collection.add.p': 'Aggiunge un chunk di testo dalla selezione corrente, o attiva la modalità cattura per immagini (doppio tap) e tabelle (long press).',
    'editor.collection.export.h': 'Export JSON',
    'editor.collection.export.p': 'Salva tutti i chunk raccolti come file JSON. Importabile in sessioni future per continuare a lavorare sulla stessa collezione.',
    'editor.collection.import.h': 'Import JSON',
    'editor.collection.import.p': 'Carica un file JSON di collezione precedentemente esportato. I chunk vengono aggiunti alla sessione corrente.',
    'editor.collection.preview.h': 'Preview',
    'editor.collection.preview.p': 'Apre il pannello Collection Inspect: lista di tutti i chunk con anteprima visiva, tipo (testo/immagine/tabella), selezione per export e pulsante elimina.',
    'editor.img.collection': 'Pannello inspect collezione con chunk raccolti',
    'editor.img.collection.caption': '📦 Collection Inspect — anteprima visiva di chunk testo, immagine e tabella',
    'editor.export.label': 'Export',
    'editor.export.h2': 'Esporta in <em>qualsiasi formato</em>',
    'editor.export.p': 'Il menu export nella sezione Tools del Noesis Editor offre molteplici formati di output per tutti i casi d\'uso.',
    'editor.img.export': 'Menu export Noesis Editor',
    'editor.img.export.caption': '📤 Menu export — tutti i formati disponibili',
    'editor.export.pdf.h': 'PDF (stampa)',
    'editor.export.pdf.p': 'Apre il dialog di stampa nativo del browser. Per rendering avanzato, usa il PDF.js Viewer dalla toolbar Tools della Library.',
    'editor.export.docx.h': 'DOCX',
    'editor.export.docx.p': 'Documento Word generato da html-docx-js con formattazione completa. Compatibile con LibreOffice, Google Docs e Microsoft Word.',
    'editor.export.md.h': 'Markdown',
    'editor.export.md.p': 'Formato Markdown convertito da Turndown. Le immagini inline vengono mantenute nella versione ZIP.',
    'editor.export.html.h': 'HTML',
    'editor.export.html.p': 'Copia l\'HTML completo negli appunti per incollarlo in WordPress, Ghost o altri CMS.',
    'editor.summernote.label': 'Summernote Editor',
    'editor.summernote.h2': 'La toolbar <em>WYSIWYG</em>',
    'editor.summernote.p': 'Noesis Editor è costruito su Summernote Lite 0.9.1 + jQuery 3.7.1. La toolbar completa offre tutti i controlli di formattazione, più estensioni specifiche di Noesis.',
    'editor.img.summernote': 'Toolbar Summernote nel Noesis Editor',
    'editor.img.summernote.caption': '✨ AI · B · I · U · S · X² · X₂ · eraser · font · size · colore · liste · allineamento · rientro · tabella · link · immagine · media · — · forbici · &lt;/&gt; · ?',
    'editor.how.step4.h': 'Registrazione in noesisLibraryDB',
    'editor.how.step4.p': 'Il capitolo viene registrato come <code>chapterRecord</code> in <code>noesisLibraryDB</code> (IndexedDB) con un <code>chapterId</code> univoco e array <code>snapshots[]</code> vuoto, pronto per il sistema di versioning.',
    'editor.unified.label': 'Ambiente Noesis Editor',
    'editor.unified.h2': 'Un solo ambiente per <em>tutto il lavoro</em>',
    'editor.unified.p': 'In precedenza esistevano due ambienti separati: il "Capitolo Estratto" e il "Report Editor". Oggi sono unificati in <strong>Noesis Editor</strong> — un singolo editor Summernote che gestisce lettura, annotazione, editing e export senza passaggi intermedi.',
    'editor.unified.chapter.h': 'Modalità chapter',
    'editor.unified.chapter.p': 'Si apre con il contenuto del capitolo estratto già caricato. Permette annotazione con highlight, gestione snapshot, raccolta chunk e editing completo del testo prima dell\'export.',
    'editor.unified.standalone.h': 'Modalità standalone',
    'editor.unified.standalone.p': 'Editor vuoto, accessibile dalla Library tramite il pulsante "Open Editor". Uso libero senza un capitolo di partenza — ideale per note, bozze e documenti indipendenti.',
    'editor.unified.callout': '<strong>Apertura in nuovo tab</strong> — Noesis Editor si apre sempre in un tab separato del browser via Blob URL. Puoi tenere aperte contemporaneamente la libreria, il reader e l\'editor per passare tra gli ambienti senza perdere il lavoro.',
    'editor.hl.label': 'Highlighting',
    'editor.hl.h2': 'Evidenzia a <em>3 colori</em>',
    'editor.hl.p': 'L\'evidenziazione a colori è disponibile nel Noesis Editor tramite Summernote nativo. Seleziona il testo e applica il colore di sfondo corrispondente alla categoria semantica.',
    'editor.hl.yellow.h': 'Giallo',
    'editor.hl.yellow.p': 'Concetti fondamentali, definizioni, informazioni chiave da memorizzare. Il colore primario dell\'annotazione accademica.',
    'editor.hl.green.h': 'Verde',
    'editor.hl.green.p': 'Esempi, citazioni, casi pratici, evidenze empiriche. Distingue il concreto dall\'astratto nel testo.',
    'editor.hl.pink.h': 'Rosa',
    'editor.hl.pink.p': 'Termini tecnici, nomi propri, vocabolario da studiare. Perfetto per lo studio linguistico e la nomenclatura specialistica.',
    'editor.hl.remove.h': 'Rimuovi highlight',
    'editor.hl.remove.p': 'Seleziona il testo evidenziato e applica "nessun colore" per rimuovere l\'highlight mantenendo il testo intatto.',
    'editor.hl.callout': '<strong>Gli highlights vengono preservati negli snapshot annotati</strong> — Save Snapshot salva due file: <code>_clean.html</code> (senza highlight) e <code>_annot.html</code> (con highlight). Puoi tornare a qualsiasi stato precedente della tua sessione di studio. <a href="snapshot.html" style="color:var(--violet);">Documentazione Snapshot →</a>',
    'editor.chapter.options.h': 'CHAPTER — Opzioni',
    'editor.chapter.options.p': 'Dropdown con opzioni aggiuntive per il capitolo corrente: rinomina, informazioni metadati e altre azioni contestuali.',
    'editor.collection.delete.h': 'COLLECTION — Elimina',
    'editor.collection.delete.p': 'Elimina tutti i chunk dalla collezione corrente dopo conferma. L\'operazione è irreversibile.',
    'editor.toolbar.tools.h': 'TOOLS',
    'editor.toolbar.tools.p': 'Apre il pannello strumenti con accesso agli helper integrati: Excalidraw, Pandoc Online e Mozilla PDF Viewer.',
    'editor.sn.ai.h': '✨ AI Assistant',
    'editor.sn.ai.p': 'Primo pulsante della toolbar. Apre il pannello AI con funzioni di riepilogo, riformulazione e analisi del testo selezionato nell\'editor.',
    'editor.sn.inline.h': 'Formattazione inline',
    'editor.sn.inline.p': '<strong>Grassetto</strong>, <em>Corsivo</em>, <u>Sottolineato</u>, <s>Barrato</s>. Applicati con i comandi Summernote sulla selezione attiva nell\'editor WYSIWYG.',
    'editor.sn.script.h': 'Apice e Pedice',
    'editor.sn.script.p': 'Apice (X²) per notazione matematica, citazioni numeriche e unità. Pedice (X₂) per formule chimiche e notazioni scientifiche.',
    'editor.sn.eraser.h': 'Eraser — Rimuovi formattazione',
    'editor.sn.eraser.p': 'Rimuove tutta la formattazione inline dalla selezione: grassetto, corsivo, colori, font-size — riporta al testo normale puro.',
    'editor.sn.lists.h': 'Liste',
    'editor.sn.lists.p': 'Lista puntata e numerata gestite da Summernote. I rientri si gestiscono con Tab/Shift+Tab o con il pulsante rientro nella toolbar.',
    'editor.sn.tables.h': 'Tabelle',
    'editor.sn.tables.p': 'Inserisce una tabella con il grid picker. Una volta inserita, la toolbar contestuale flottante permette di aggiungere/eliminare righe e colonne senza codice.',
    'editor.sn.link.h': 'Link',
    'editor.sn.link.p': 'Inserisce o modifica un collegamento ipertestuale sulla selezione. Apre un popup con il campo URL e l\'opzione di apertura in nuova tab.',
    'editor.sn.media.h': 'Media',
    'editor.sn.media.p': 'Inserisce un elemento video o audio tramite URL embed. Utile per integrare contenuti multimediali direttamente nel documento.',
    'editor.img.editing': 'Editor WYSIWYG con toolbar Summernote',
    'editor.img.editing.caption': '✏️ Noesis Editor — toolbar Summernote completa con formattazione e plugin',
    'editor.table.label': 'Plugin Tabelle',
    'editor.table.h2': 'Gestione tabelle <em>senza codice</em>',
    'editor.table.p': 'Il plugin tabelle aggiunge una toolbar contestuale flottante che appare automaticamente quando il cursore si trova in una cella. Tutte le operazioni sulla struttura sono disponibili con un click.',
    'editor.table.rowabove.h': 'Inserisci riga sopra',
    'editor.table.rowabove.p': 'Inserisce una nuova riga vuota immediatamente sopra la riga in cui si trova il cursore.',
    'editor.table.rowbelow.h': 'Inserisci riga sotto',
    'editor.table.rowbelow.p': 'Inserisce una nuova riga vuota immediatamente sotto la riga corrente.',
    'editor.table.colleft.h': 'Inserisci colonna sinistra',
    'editor.table.colleft.p': 'Aggiunge una nuova colonna vuota a sinistra della colonna corrente.',
    'editor.table.colright.h': 'Inserisci colonna destra',
    'editor.table.colright.p': 'Aggiunge una nuova colonna vuota a destra della colonna corrente.',
    'editor.table.delrow.h': 'Elimina riga',
    'editor.table.delrow.p': 'Rimuove completamente la riga in cui si trova il cursore con tutti i suoi contenuti.',
    'editor.table.delcol.h': 'Elimina colonna',
    'editor.table.delcol.p': 'Rimuove completamente la colonna corrente con tutti i suoi contenuti.',
    'editor.img.table': 'Plugin Table Editor con toolbar flottante',
    'editor.img.table.caption': '⊞ Table Editor — toolbar contestuale flottante con le operazioni sulla struttura',
    'editor.imgplugin.label': 'Plugin Immagini',
    'editor.imgplugin.h2': 'Ridimensionamento <em>visuale</em>',
    'editor.imgplugin.p': 'Il plugin Image Resizer permette di ridimensionare le immagini direttamente nell\'editor trascinando i handles, senza bisogno di inserire dimensioni manualmente.',
    'editor.imgplugin.select.h': 'Selezione visiva',
    'editor.imgplugin.select.p': 'Cliccando su un\'immagine nel documento, appare un overlay di selezione con handles agli angoli e ai lati centrali — esattamente come nei programmi di grafica.',
    'editor.imgplugin.resize.h': 'Ridimensionamento drag',
    'editor.imgplugin.resize.p': 'Trascina i handles per scalare l\'immagine. Il plugin aggiorna <code>width</code> e <code>height</code> dell\'elemento in tempo reale durante il trascinamento.',
    'editor.imgplugin.img': 'Plugin Image Resizer con handles di ridimensionamento',
    'editor.imgplugin.img.caption': '↔️ Image Resizer — handles di selezione e ridimensionamento visuale',
    'editor.imgplugin.callout': '<strong>Immagini sempre base64</strong> — Tutte le immagini nell\'editor sono salvate come base64 inline: sia quelle provenienti dall\'EPUB estratto, sia quelle importate da file locale. Il documento esportato è sempre autocontenuto e portabile.',
    'editor.excalidraw.fork.h': 'Fork locale Noesis',
    'editor.excalidraw.fork.p': 'Excalidraw è incluso come fork integrato nell\'applicazione — nessuna CDN esterna, nessun upload di dati. Si apre in un tab separato del browser e lavora completamente offline.',
    'editor.excalidraw.export.h': 'SVG e PNG',
    'editor.excalidraw.export.p': 'Esporta i tuoi diagrammi in SVG (vettoriale, scalabile infinitamente) o PNG (raster per embed immediato). Inserisci poi il file nel documento tramite il plugin immagini dell\'editor.',
    'editor.excalidraw.create.h': 'Cosa puoi creare',
    'editor.excalidraw.create.p': 'Flowchart concettuali, mappe mentali, diagrammi causa-effetto, schemi di relazioni, timeline visive. Qualsiasi struttura visiva a supporto dei tuoi appunti di studio.',
    'editor.excalidraw.privacy.h': 'Nessun dato condiviso',
    'editor.excalidraw.privacy.p': 'Il fork Noesis di Excalidraw non invia nulla a server esterni. I tuoi diagrammi rimangono locali fino a quando non li esporti manualmente come file.',
    'editor.export.txt.h': 'TXT',
    'editor.export.txt.p': 'Testo semplice senza formattazione. Ideale per pipeline di analisi, input a modelli LLM, o archiviazione leggera del contenuto testuale.',
    'editor.export.mdzip.h': 'Markdown + ZIP',
    'editor.export.mdzip.p': 'Markdown con le immagini estratte come file separati e impacchettate in uno ZIP. Ideale per documenti con molte immagini base64 da pubblicare su piattaforme che accettano upload di asset.',
    'editor.export.json.h': 'JSON',
    'editor.export.json.p': 'Struttura dati completa del documento in formato JSON. Utile per integrazioni programmatiche, backup strutturati o import in altri sistemi.',
    'editor.export.callout': '<strong>Export collezioni</strong> — Il menu export include anche le opzioni per esportare la collezione corrente: JSON, HTML, MD e MD+ZIP. Queste opzioni lavorano sui chunk raccolti, non sul testo dell\'editor. <a href="collezioni.html" style="color:var(--violet);">Documentazione Collezioni →</a>',
    'editor.quickexport.label': 'Export Rapido',
    'editor.quickexport.h2': 'Esporta il capitolo <em>direttamente</em>',
    'editor.quickexport.p': 'Oltre al menu export completo, Noesis Editor offre pulsanti di export rapido nella toolbar per esportare il contenuto del capitolo estratto senza passare per l\'editor.',
    'editor.quickexport.pdf.h': 'Print / Save PDF',
    'editor.quickexport.pdf.p': 'Stampa nativa del browser con CSS <code>@media print</code> ottimizzati — nasconde toolbar, gestisce page-break, preserva colori. Salva come PDF dal dialog del browser.',
    'editor.quickexport.docx.h': 'Save as DOCX',
    'editor.quickexport.docx.p': 'Esporta il capitolo in formato Word con download automatico. Il file DOCX è compatibile con Microsoft Word, Google Docs e LibreOffice.',
    'editor.quickexport.pdfviewer.h': 'PDF Viewer',
    'editor.quickexport.pdfviewer.p': 'Apre Mozilla PDF.js in una nuova tab con il contenuto del capitolo — rendering ad alta qualità, zoom, ricerca testuale e stampa diretta dal viewer.',
    'editor.quickexport.callout': '<strong>Immagini sempre visibili</strong> — Tutte le immagini sono salvate come base64 inline nel documento estratto. I PDF e DOCX esportati sono completamente standalone — nessun path esterno da mantenere, nessuna immagine rotta.',
    'editor.chunks.label': 'Raccolta Chunk',
    'editor.chunks.h2': 'Collect, ispeziona e <em>inietta chunk</em>',
    'editor.chunks.p': 'Durante la lettura nel Noesis Reading puoi raccogliere chunk di testo — paragrafi, citazioni, estratti — nella collezione. Nel Noesis Editor l\'Inspect Panel ti permette di visualizzare i chunk raccolti e iniettarli nel documento corrente con un click.',
    'editor.chunks.inspect.h': 'Inspect Panel',
    'editor.chunks.inspect.p': 'Il pannello laterale dell\'editor mostra tutti i chunk nella collezione corrente con titolo, testo e origine. Disponibile sia in modalità <em>chapter</em> che <em>standalone</em>.',
    'editor.chunks.inject.h': 'Inietta nel documento',
    'editor.chunks.inject.p': 'Clicca su un chunk per inserirlo nel punto di inserimento corrente del documento. Il testo viene incollato come HTML formattato, preservando la struttura del paragrafo originale.',
    'editor.img.chunks': 'Inspect Panel della collezione nel Noesis Editor',
    'editor.img.chunks.caption': '📌 Inspect Panel — chunk raccolti durante la lettura, pronti per l\'iniezione nel documento',
    'editor.chunks.callout': '<strong>Chunk e collezioni</strong> — I chunk vengono salvati in <code>noesisCollectionDB</code> (IndexedDB) per libro. Puoi raccogliere durante più sessioni di lettura e ritrovarli sempre disponibili nell\'Inspect Panel. <a href="collezioni.html" style="color:var(--violet);">Documentazione Collezioni →</a>',
    'editor.importsnap.label': 'Importa Snapshot',
    'editor.importsnap.h2': 'Ricarica una <em>versione precedente</em>',
    'editor.importsnap.p': 'Il Noesis Editor permette di importare snapshot precedentemente salvati su filesystem — anche di sessioni diverse o da altri dispositivi. Il sistema legge i meta tag Noesis incorporati nel file e ripristina il contesto corretto.',
    'editor.importsnap.file.h': 'Import da file',
    'editor.importsnap.file.p': 'Usa il pulsante <strong>Import Snapshot</strong> nella toolbar dell\'editor per aprire il file picker. Seleziona un file <code>_annot.html</code> o <code>_clean.html</code> precedentemente salvato.',
    'editor.importsnap.meta.h': 'Meta tag Noesis',
    'editor.importsnap.meta.p': 'Ogni snapshot contiene meta tag con <code>chapterId</code>, nome libro e variante. Il sistema li legge automaticamente e riconnette il documento alla gerarchia Library corretta.',
    'editor.img.importsnap': 'Import Snapshot nel Noesis Editor',
    'editor.img.importsnap.caption': '📂 Import Snapshot — caricamento di versioni precedenti con riconnessione automatica al capitolo',
    'editor.pagenav.prev': '← Noesis Reading',
    'editor.pagenav.next': 'Snapshot →',

    // SNAPSHOT (abbreviated)
    'snapshot.meta.desc': 'Il sistema di versioning a snapshot di Noesis v810 — salva, ricarica ed elimina versioni del capitolo estratto.',
    'snapshot.hero.badge': 'v810 · Sistema Snapshot',
    'snapshot.hero.h1': 'Versioning del tuo <em>lavoro di studio</em>',
    'snapshot.hero.p': 'Salva lo stato del capitolo estratto in qualsiasi momento. Ricarica qualsiasi versione precedente con un click. File HTML su filesystem locale, nessun cloud.',
    'snapshot.intro.label': "Cos'è",
    'snapshot.intro.h2': 'Versioning <em>locale</em> per i tuoi appunti',
    'snapshot.intro.p': 'Il problema: quando lavori su un capitolo estratto — aggiungendo highlights, note e chunk — non puoi tornare a una versione precedente. Un\'azione sbagliata è irreversibile. Il sistema Snapshot risolve questo.',
    'snapshot.callout.new': '<strong>v810 — Snapshot su filesystem</strong>Nessun reader EPUB o strumento di studio offline offre versioning persistente del lavoro di annotazione direttamente integrato nel flusso di lettura, senza cloud e senza account.',
    'snapshot.flow.extract.h': 'Estrai capitolo',
    'snapshot.flow.extract.p': 'Il capitolo apre in una nuova tab con ID univoco',
    'snapshot.flow.study.h': 'Studia',
    'snapshot.flow.study.p': 'Highlights, annotazioni, raccogli chunk',
    'snapshot.flow.save.h': 'Salva snapshot',
    'snapshot.flow.save.p': 'Versione congelata con descrizione',
    'snapshot.save.label': 'Salva uno snapshot',
    'snapshot.save.h2': 'Fotografa il tuo <em>lavoro</em>',
    'snapshot.save.p': 'Gli snapshot si creano direttamente dal Noesis Editor, non dalla Library. Quando lavori su un capitolo estratto, ogni volta che vuoi salvare una versione puoi farlo con un click.',
    'snapshot.save.step1.h': 'Apri il capitolo nell\'Editor',
    'snapshot.save.step1.p': 'Dalla Library, clicca sul nome del capitolo (apre l\'ultimo snapshot) oppure su uno snapshot specifico. L\'Editor si apre in una nuova scheda.',
    'snapshot.save.step2.h': 'Clicca il pulsante Save nella bottoniera Chapter',
    'snapshot.save.step2.p': 'Il pulsante verde <strong>Save</strong> (<code>bi-file-earmark-arrow-down</code>) nella sezione Chapter della bottoniera inferiore. Si apre un prompt che mostra il nome file proposto.',
    'snapshot.save.step3.h': 'Opzionale: aggiungi un\'etichetta',
    'snapshot.save.step3.p': 'Il prompt permette di aggiungere un\'etichetta personalizzata al nome file. Esempi: <em>"primaLettura"</em>, <em>"dopoChunk"</em>, <em>"versioneFinale"</em>. Lascia vuoto per usare solo timestamp.',
    'snapshot.save.step4.h': 'Conferma per salvare',
    'snapshot.save.step4.p': 'Noesis produce <strong>due file HTML</strong> simultaneamente: versione <em>clean</em> (senza colori highlight) e <em>annotated</em> (con tutti i colori). Entrambi vengono scaricati e salvati anche in IndexedDB. Appare un toast di conferma.',
    'snapshot.callout.backup': '<strong>Doppia copia di sicurezza</strong> — Ogni snapshot viene salvato sia come file HTML nella cartella Download (portatile, archiviabile su cloud) sia in IndexedDB (accesso immediato dalla Library). Se cancelli i dati del browser, puoi reimportare i file HTML tramite <strong>Import Snapshots</strong> nella Library.',
    'snapshot.history.label': 'Gestione cronologia',
    'snapshot.history.h2': 'Il pannello <em>Snapshot History</em>',
    'snapshot.history.p': 'Il pannello Snapshot History nel Noesis Editor mostra tutte le versioni salvate per il capitolo corrente, in ordine cronologico inverso.',
    'snapshot.history.load.h': 'Carica uno snapshot',
    'snapshot.history.load.p': 'Clicca <strong>Load</strong> accanto a uno snapshot per ripristinare quella versione nell\'editor. Il contenuto corrente viene sostituito. <strong>Salva uno snapshot prima di fare Load</strong> se vuoi conservare la versione corrente.',
    'snapshot.history.delete.h': 'Eliminare uno snapshot',
    'snapshot.history.delete.p': 'Clicca il pulsante rosso di eliminazione per rimuovere uno snapshot da IndexedDB. Il file HTML sul filesystem <strong>non</strong> viene eliminato — resta disponibile per reimportazione futura.',
    'snapshot.import.label': 'Reimportare da filesystem',
    'snapshot.import.h2': 'Import <em>Snapshots</em>',
    'snapshot.import.p': 'Se hai cancellato i dati IndexedDB o stai lavorando da un dispositivo diverso, puoi reimportare i file HTML degli snapshot direttamente dal filesystem.',
    'snapshot.import.step1.h': 'Clicca Import Snapshots nella Library',
    'snapshot.import.step1.p': 'Nella toolbar di Noesis Library, clicca <strong>Import Snapshots</strong>. Si apre un file picker che accetta più file HTML simultaneamente.',
    'snapshot.import.step2.h': 'Seleziona i file HTML degli snapshot',
    'snapshot.import.step2.p': 'Seleziona i file HTML precedentemente scaricati. Noesis legge i meta tag incorporati (<code>noesis-chapter-id</code>, <code>noesis-book-name</code>) per identificare correttamente il libro e il capitolo.',
    'snapshot.import.step3.h': 'La libreria si aggiorna automaticamente',
    'snapshot.import.step3.p': 'Ogni snapshot reimportato appare sotto il libro e il capitolo corrispondente nella libreria gerarchica. Subito accessibile con un click.',
    'snapshot.schema.label': 'Schema tecnico',
    'snapshot.schema.h2': 'La struttura di <em>noesisDB</em>',
    'snapshot.schema.p': 'Il database noesisDB (IndexedDB) conserva solo metadati leggeri — il contenuto HTML degli snapshot vive sul filesystem.',
    'snapshot.img.library': 'Libreria gerarchica con capitoli estratti e snapshot',
    'snapshot.img.library.caption': '📚 Library — capitoli estratti con relativi snapshot in ordine cronologico',
    'snapshot.img.import': 'Dialog Import Snapshots — selezione file da disco',
    'snapshot.img.import.caption': '⬆️ Import Snapshots — seleziona i file snapshot HTML per reimportarli nella Library',
    'snapshot.history.h2': 'Gestisci la <em>cronologia</em> dalla Library',
    'snapshot.history.p': 'La cronologia degli snapshot si gestisce dalla Library, non dall\'Editor. Ogni capitolo estratto mostra la lista degli snapshot salvati. Da qui puoi caricare (Load) o eliminare qualsiasi versione.',
    'snapshot.history.callout': '<strong>Load sovrascrive il contenuto corrente</strong> — Ripristinare uno snapshot sostituisce completamente il testo visibile nel capitolo. Se hai modifiche non salvate, salva uno snapshot prima di fare Load.',
    'snapshot.access.label': 'Libreria Gerarchica',
    'snapshot.access.h2': 'Accedi agli snapshot <em>dalla libreria</em>',
    'snapshot.access.p': 'La libreria gerarchica (v810) mostra tutti i capitoli estratti con i loro snapshot. Da qui puoi <strong>aprire</strong> qualsiasi versione nell\'Editor, ma gli snapshot si creano dall\'Editor (vedi sezione precedente). La Library serve a navigare e gestire le versioni salvate.',
    'snapshot.access.cover.h': 'Click sulla copertina',
    'snapshot.access.cover.p': 'Apre il libro nel reader. Navighi il libro normalmente e puoi estrarre nuovi capitoli.',
    'snapshot.access.chapter.h': 'Click sul nome capitolo',
    'snapshot.access.chapter.p': 'Apre il Noesis Editor con lo snapshot <strong>più recente</strong>. Accesso rapido all\'ultima versione del tuo lavoro.',
    'snapshot.access.snapshot.h': 'Click sul nome snapshot',
    'snapshot.access.snapshot.p': 'Apre il Noesis Editor con quello specifico snapshot. Accesso diretto a qualsiasi versione storica.',
    'snapshot.schema.files.h': 'File HTML reali',
    'snapshot.schema.files.p': 'Ogni snapshot è un file HTML standalone — visibile nel filesystem, portabile, archiviabile in Git o su cloud storage a scelta dell\'utente.',
    'snapshot.schema.manual.h': 'Versioning manuale',
    'snapshot.schema.manual.p': 'L\'utente controlla esplicitamente quando salvare. Non c\'è auto-save degli snapshot — solo il lavoro che scegli di fotografare viene conservato.',
    'snapshot.schema.reimport.h': 'Reimportazione',
    'snapshot.schema.reimport.p': 'I file snapshot possono essere reimportati in qualsiasi momento via <strong>Import Snapshots</strong> nella Library — Noesis li riconosce tramite meta tag <code>noesis-*</code>.',
    'snapshot.schema.cleanup.h': 'Pulizia via filesystem',
    'snapshot.schema.cleanup.p': 'Gestisci gli snapshot come normali file: rinominali, spostali, archivia quelli vecchi. Non c\'è database da svuotare.',
    'snapshot.scenarios.label': 'Scenari d\'uso',
    'snapshot.scenarios.h2': 'Tre modi di usare <em>gli snapshot</em>',
    'snapshot.scenarios.study.btn': '📚 Studio progressivo — versioni successive',
    'snapshot.scenarios.study.body': '<p>Estrai il capitolo → salva snapshot <em>"Testo originale"</em>.<br>Prima lettura con highlights gialli → salva snapshot <em>"Prima lettura"</em>.<br>Seconda lettura con highlights verdi e rosa → salva snapshot <em>"Studio approfondito"</em>.<br>Raccolta chunk per il report → salva snapshot <em>"Chunk raccolti"</em>.<br>Hai ora 4 versioni del capitolo, ognuna con il suo stato di studio preciso.</p>',
    'snapshot.scenarios.research.btn': '🔬 Ricerca — varianti parallele',
    'snapshot.scenarios.research.body': '<p>Estrai il capitolo → salva snapshot <em>"Base"</em>.<br>Annota con la prima ipotesi interpretativa → salva snapshot <em>"Ipotesi A"</em>.<br>Ricarica snapshot <em>"Base"</em> → annota con la seconda ipotesi → salva snapshot <em>"Ipotesi B"</em>.<br>Puoi mantenere versioni parallele dello stesso capitolo con interpretazioni diverse.</p>',
    'snapshot.scenarios.backup.btn': '💼 Sicurezza — backup prima di operazioni rischiose',
    'snapshot.scenarios.backup.body': '<p>Prima di qualsiasi operazione potenzialmente distruttiva (riorganizzare i chunk, cancellare highlights, caricare un nuovo lancio dall\'editor) → salva snapshot.<br>Se il risultato non ti soddisfa → Load per tornare alla versione pre-operazione.<br>È un <em>checkpoint</em> manuale prima di ogni fase critica del lavoro.</p>',
    'snapshot.pagenav.prev': '← Noesis Editor',
    'snapshot.pagenav.next': 'Collezioni →',

    // COLLECTIONS (abbreviated)
    'collections.meta.desc': 'Sistema di raccolta chunk: testo, immagini e tabelle. Import/export JSON, ispezione e selezione per capitolo in Noesis.',
    'collections.hero.badge': 'Manuale d\'uso · Collezioni',
    'collections.hero.h1': 'Raccogli i <em>contenuti</em>',
    'collections.hero.p': 'Sistema di raccolta chunk per testo, immagini e tabelle. Ispeziona, seleziona, esporta in JSON e alimenta l\'editor con i tuoi materiali di studio.',
    'collections.intro.label': 'Sistema chunk',
    'collections.intro.h2': "Cos'è una <em>collezione</em>",
    'collections.intro.p': 'Una collezione è un contenitore di frammenti di contenuto — detti <strong>chunk</strong> — raccolti mentre lavori su un capitolo nel Noesis Editor. Ogni chunk può essere testo selezionato, un\'immagine o una tabella HTML.',
    'collections.callout.memory': '<strong>La collezione è in-memory durante la sessione Editor</strong>I chunk vengono mantenuti in memoria durante la sessione di lavoro nell\'Editor. Per conservarli tra sessioni o condividerli, usa il pulsante <strong>Export JSON</strong> nella bottoniera Collection per salvare un file JSON.',
    'collections.card.text.h': 'Chunk di testo',
    'collections.card.text.p': 'Qualsiasi selezione di testo nel capitolo nell\'Editor. Include la formattazione HTML (grassetto, corsivo, link).',
    'collections.card.images.h': 'Chunk di immagini',
    'collections.card.images.p': 'Immagini salvate come base64 inline. Perfette per grafici, diagrammi e figure da riutilizzare nell\'editor senza dipendenze esterne.',
    'collections.card.tables.h': 'Chunk di tabelle',
    'collections.card.tables.p': 'Tabelle HTML con struttura preservata fedelmente — righe, colonne, celle e attributi. Pronte per essere modificate nell\'editor WYSIWYG.',
    'collections.add.label': 'Raccolta',
    'collections.add.h2': 'Come aggiungere <em>chunk</em> nell\'Editor',
    'collections.add.p': 'I chunk si raccolgono direttamente nell\'Editor WYSIWYG, usando la bottoniera Collection nella parte inferiore della finestra.',
    'collections.add.step1.h': 'Testo — Seleziona e clicca [+]',
    'collections.add.step1.p': 'Seleziona il testo desiderato nell\'editor con il mouse o touch. Clicca il pulsante <strong>[+]</strong> nella sezione Collection della bottoniera inferiore. Un toast conferma l\'aggiunta.',
    'collections.add.step2.h': 'Immagini — Doppio tap o long press',
    'collections.add.step2.p': '<strong>Doppio tap</strong> (desktop) o <strong>long press</strong> (600ms, Android) su un\'immagine nell\'editor. L\'immagine viene aggiunta direttamente senza bisogno del pulsante [+].',
    'collections.add.step3.h': 'Tabelle — Long press sulla tabella',
    'collections.add.step3.p': '<strong>Long press</strong> (600ms) su una cella della tabella. L\'intera tabella viene aggiunta come chunk.',
    'collections.img.collection': 'Noesis Editor — pannello Collection inspect',
    'collections.img.collection.caption': '📦 Collection Inspect — lista chunk raccolti con anteprima e opzioni di gestione',
    'collections.inspect.label': 'Pannello inspect',
    'collections.inspect.h2': 'Visualizza e gestisci i <em>chunk</em>',
    'collections.inspect.p': 'Il pannello Collection Inspect si apre in un overlay flottante non modale nell\'editor. Mostra tutti i chunk raccolti con anteprima visiva.',
    'collections.inspect.preview.h': 'Anteprima visiva',
    'collections.inspect.preview.p': 'Ogni chunk mostra un\'anteprima del contenuto: testo troncato per chunk di testo, thumbnail per immagini, prima riga per tabelle.',
    'collections.inspect.select.h': 'Selezione per export',
    'collections.inspect.select.p': 'Puoi selezionare/deselezionare chunk individuali per l\'export. Export JSON rispetta la selezione corrente.',
    'collections.inspect.delete.h': 'Eliminare chunk',
    'collections.inspect.delete.p': 'Ogni chunk ha un pulsante di eliminazione. La rimozione è immediata e non influisce sul contenuto dell\'editor.',
    'collections.export.label': 'Import / Export',
    'collections.export.h2': 'Persistenza tra <em>sessioni</em>',
    'collections.export.p': 'Il formato JSON è il ponte per trasportare collezioni tra sessioni, dispositivi o editor.',
    'collections.export.json.h': 'Export JSON',
    'collections.export.json.p': 'Salva tutti i chunk (o solo quelli selezionati) in un file JSON. Il formato include tipo (testo/immagine/tabella), contenuto HTML e metadati della collezione.',
    'collections.import.json.h': 'Import JSON',
    'collections.import.json.p': 'Carica un file JSON precedentemente esportato. I chunk vengono aggiunti alla sessione corrente. Compatibile con tutte le versioni di Noesis Editor dalla v700 in poi.',
    'collections.use.label': 'Uso pratico',
    'collections.use.h2': 'Costruisci un documento dai <em>chunk</em>',
    'collections.use.p': 'Il workflow di collezione permette di assemblare materiale di studio da più capitoli in un unico documento coerente.',
    'collections.use.step1.h': 'Raccogli mentre leggi',
    'collections.use.step1.p': 'Mentre lavori su capitoli estratti, aggiungi i passaggi chiave, le immagini significative e le tabelle rilevanti alla collezione.',
    'collections.use.step2.h': 'Esporta e reimporta',
    'collections.use.step2.p': 'A fine sessione, esporta il JSON. Apri Noesis Editor in modalità standalone (Open Editor dalla Library), importa il JSON.',
    'collections.use.step3.h': 'Assembla ed esporta',
    'collections.use.step3.p': 'Usa i chunk come mattoni per assemblare il documento finale. Esporta come PDF, DOCX o Markdown.',
    'collections.add.p': 'I chunk si raccolgono direttamente nell\'Editor WYSIWYG, usando la bottoniera Collection nella parte inferiore della finestra.',
    'collections.add.badge.h': 'Badge contatore',
    'collections.add.badge.p': 'Il pulsante <strong>[+]</strong> mostra un badge rosso con il numero totale di chunk attualmente in collezione. Si aggiorna in tempo reale ad ogni operazione.',
    'collections.add.clear.h': 'Svuota collezione',
    'collections.add.clear.p': 'Clicca il pulsante <strong>Clear</strong> (icona 🗑️, rosso) nella bottoniera Collection per svuotare tutta la collezione. Appare una richiesta di conferma.',
    'collections.img.editor': 'Noesis Editor con bottoniera Collection',
    'collections.img.editor.caption': '✏️ Noesis Editor — bottoniera Collection in basso: [+], Import, Export, Inspect, Clear',
    'collections.export.callout': '<strong>Workflow consigliato con snapshot</strong> — Prima di svuotare una collezione, salva uno snapshot del capitolo. Lo snapshot conserva lo stato del documento (inclusi gli highlights) mentre il JSON conserva i chunk raccolti. Hai così due backup complementari del tuo lavoro.',
    'collections.use.link': 'Scopri l\'Editor WYSIWYG →',
    'collections.pagenav.prev': '← Snapshot',
    'collections.pagenav.next': 'Helpers →',

    // HELPERS (abbreviated)
    'helpers.meta.desc': 'ePub Slimmer, Multi ePub Slimmer, ePub Splitter e PDF.js Viewer — strumenti aggiuntivi per gestire i tuoi EPUB nel browser.',
    'helpers.hero.badge': 'Manuale d\'uso · Helper Tools',
    'helpers.hero.h1': 'Strumenti <em>aggiuntivi</em>',
    'helpers.hero.p': 'Quattro tool per gestire i tuoi EPUB: PDF Viewer di alta qualità, compressione immagini singola e batch, e splitter per estrarre capitoli come file separati. Tutto nel browser.',
    'helpers.pdfjs.label': 'Tool 1',
    'helpers.pdfjs.h2': 'Mozilla <em>PDF.js Viewer</em>',
    'helpers.pdfjs.p': 'Visualizzazione di alta qualità dei capitoli estratti tramite il viewer PDF open-source di Mozilla. Integrato nel flusso di export del capitolo estratto.',
    'helpers.pdfjs.view.h': '📖 Visualizzazione avanzata',
    'helpers.pdfjs.view.p': 'Rendering PDF di alta qualità con supporto per font incorporati, layout complessi e colori accurati — superiore al dialog di stampa del browser.',
    'helpers.pdfjs.zoom.h': '🔍 Zoom e navigazione',
    'helpers.pdfjs.zoom.p': 'Zoom avanti e indietro con percentuale precisa, navigazione tra pagine con input diretto del numero, visualizzazione a schermo intero.',
    'helpers.pdfjs.search.h': '🔎 Ricerca testuale',
    'helpers.pdfjs.search.p': 'Ricerca full-text nel documento PDF con evidenziazione dei risultati. Utile per trovare rapidamente termini specifici in capitoli lunghi.',
    'helpers.pdfjs.print.h': '🖨️ Stampa diretta',
    'helpers.pdfjs.print.p': 'Stampa il PDF direttamente dal viewer usando le funzionalità native del browser, con layout ottimizzato per la stampa.',
    'helpers.img.mozilla': 'PDF.js Viewer con capitolo estratto',
    'helpers.img.mozilla.caption': '📖 PDF.js Viewer — rendering di alta qualità del capitolo estratto',
    'helpers.slimmer.label': 'Tool 2',
    'helpers.slimmer.h2': '<em>ePub Slimmer</em>',
    'helpers.slimmer.p': 'Comprime le immagini in un file EPUB per ridurne le dimensioni. Utile per EPUB con molte immagini ad alta risoluzione che rallentano il caricamento.',
    'helpers.slimmer.compress.h': '🖼️ Compressione immagini',
    'helpers.slimmer.compress.p': 'Comprime tutte le immagini dell\'EPUB in JPEG con qualità configurabile. Mantiene l\'aspect ratio e la struttura delle immagini.',
    'helpers.slimmer.quality.h': '⚙️ Qualità configurabile',
    'helpers.slimmer.quality.p': 'Regola la qualità di compressione (0–100). Valori tra 60–80 offrono un buon bilanciamento tra dimensione e qualità per la maggior parte degli EPUB.',
    'helpers.slimmer.nodrm.h': '🔒 No DRM',
    'helpers.slimmer.nodrm.p': 'Funziona solo con EPUB privi di DRM. I file protetti non possono essere elaborati.',
    'helpers.multislimmer.label': 'Tool 3',
    'helpers.multislimmer.h2': '<em>Multi ePub Slimmer</em>',
    'helpers.multislimmer.p': 'Versione batch di ePub Slimmer. Elabora più file EPUB simultaneamente con le stesse impostazioni di compressione.',
    'helpers.multislimmer.batch.h': '📚 Elaborazione batch',
    'helpers.multislimmer.batch.p': 'Seleziona più EPUB contemporaneamente. Ognuno viene compresso indipendentemente e scaricato automaticamente.',
    'helpers.multislimmer.progress.h': '📊 Progresso',
    'helpers.multislimmer.progress.p': 'Barra di progresso per ogni EPUB durante l\'elaborazione. I file elaborati compaiono nella lista risultati man mano che completano.',
    'helpers.splitter.label': 'Tool 4',
    'helpers.splitter.h2': '<em>ePub Splitter</em>',
    'helpers.splitter.p': 'Divide un EPUB in file capitolo individuali. Ogni capitolo viene salvato come EPUB separato — utile per strumenti di lettura che gestiscono male EPUB grandi.',
    'helpers.splitter.split.h': '✂️ Divisione per capitolo',
    'helpers.splitter.split.p': 'Ogni elemento della spine EPUB diventa un EPUB separato con metadati corretti. I nomi dei capitoli vengono presi dal TOC.',
    'helpers.splitter.download.h': '📦 Download ZIP',
    'helpers.splitter.download.p': 'Tutti gli EPUB divisi vengono impacchettati in un unico file ZIP per il download. Nessun passaggio intermedio.',
    'helpers.pdfjs.callout': '<strong>Come accedere al PDF Viewer</strong> — Il PDF Viewer si attiva dal pulsante <strong>👁 PDF Viewer</strong> nella toolbar del capitolo estratto. Non è una pagina separata — è integrato nel flusso di export del capitolo.',
    'helpers.pdfjs.meta.p': 'Rendering PDF di alta qualità direttamente nel browser',
    'helpers.slimmer.meta.p': 'Compressione immagini per un singolo file EPUB',
    'helpers.slimmer.link': 'Apri tool →',
    'helpers.multislimmer.meta.p': 'Compressione batch di fino a 10 file EPUB',
    'helpers.multislimmer.link': 'Apri tool →',
    'helpers.multislimmer.queue.h': '🔢 Coda con stato individuale',
    'helpers.multislimmer.queue.p': 'Ogni file mostra il proprio stato: <span class="badge badge-gray">pending</span> → <span class="badge badge-violet">processing</span> → <span class="badge badge-green">done</span> oppure <span class="badge badge-red">error</span>.',
    'helpers.multislimmer.error.h': '⚠️ Gestione errori',
    'helpers.multislimmer.error.p': 'Se un file fallisce (EPUB corrotto, formato non supportato) gli altri continuano l\'elaborazione. Messaggi di errore chiari per ogni file problematico.',
    'helpers.splitter.meta.p': 'Estrazione di capitoli selezionati come file EPUB separati',
    'helpers.splitter.link': 'Apri tool →',
    'helpers.splitter.callout': '<strong>Differenza con Extract Chapter</strong> — Lo Splitter produce file <code>.epub</code> autonomi (importabili in altri reader). La funzione Extract Chapter di Noesis produce documenti HTML standalone con la toolbar Noesis integrata. Sono strumenti complementari con scopi diversi.',
    'helpers.pagenav.prev': '← Collezioni',
    'helpers.pagenav.next': 'FAQ →',

    // FAQ (abbreviated)
    'faq.meta.desc': 'Domande frequenti su Noesis: import EPUB, snapshot, collezioni, export, compatibilità browser e risoluzione problemi.',
    'faq.hero.badge': 'Supporto · FAQ',
    'faq.hero.h1': 'Domande <em>Frequenti</em>',
    'faq.hero.p': 'Risposte alle domande più comuni su Noesis — dall\'installazione agli snapshot, dalla privacy alla compatibilità browser.',
    'faq.setup.label': 'Primo avvio',
    'faq.setup.h2': 'Installazione e <em>setup</em>',
    'faq.q.install': 'Come installo Noesis?',
    'faq.a.install.p1': 'Non c\'è nulla da installare. Scarica <code>noesis810.zip</code> dalla homepage, decomprimilo e fai doppio click su <code>noesis810.html</code>. Il file si apre nel browser e l\'app è pronta.',
    'faq.a.install.p2': 'Per la migliore esperienza (specialmente con EPUB che hanno risorse esterne) avvia un server locale: <code>python -m http.server 8000</code> nella cartella decompressa, poi apri <code>http://localhost:8000/noesis810.html</code>.',
    'faq.q.browsers': 'Quali browser supporta Noesis?',
    'faq.q.mobile': 'Funziona su mobile?',
    'faq.a.mobile': 'Sì, Noesis è responsive e funziona su browser mobile moderni. L\'interfaccia si adatta agli schermi piccoli con menu hamburger per la navigazione. Tuttavia, Noesis è ottimizzato principalmente per l\'uso desktop — la produzione di documenti (editor, export, gestione snapshot) è più comoda su computer con tastiera e schermo grande.',
    'faq.q.internet': 'Noesis richiede connessione internet?',
    'faq.a.internet': 'Solo per il primo caricamento (scarica le librerie CDN: ePub.js, JSZip, Bootstrap Icons, jQuery, Summernote, Mozilla PDF.js). Dopo il primo avvio, Noesis funziona completamente offline. La traduzione browser richiede connessione internet (il servizio di traduzione è del browser, non di Noesis).',
    'faq.books.label': 'Libri e libreria',
    'faq.books.h2': 'Import e gestione <em>libri</em>',
    'faq.q.noload': 'Il libro non si carica — cosa faccio?',
    'faq.a.noload.1': '<strong>1. Verifica che il file sia un EPUB valido</strong> e non sia protetto da DRM. Noesis non supporta file con DRM.',
    'faq.a.noload.2': '<strong>2. Usa un server locale.</strong> Apri una shell nella cartella di Noesis ed esegui <code>python -m http.server 8000</code>, poi accedi a <code>http://localhost:8000/noesis810.html</code>. Molti problemi di caricamento EPUB sono dovuti a restrizioni CORS con il protocollo <code>file://</code>.',
    'faq.a.noload.3': '<strong>3. Controlla IndexedDB</strong> in DevTools → Application → Storage → IndexedDB → EpubLibraryDB → books per verificare se il libro è stato salvato.',
    'faq.q.howmany': 'Quanti libri posso tenere in libreria?',
    'faq.a.howmany': 'Tecnicamente illimitati — la libreria è vincolata solo dallo spazio disponibile in IndexedDB del browser. In pratica, i browser moderni concedono 50–100MB di storage IndexedDB per default (espandibile). Un EPUB medio è 2–5MB, un EPUB con molte immagini può arrivare a 50–100MB. Usa l\'ePub Slimmer se hai EPUB di grandi dimensioni.',
    'faq.q.images': 'Le immagini nel libro non si visualizzano',
    'faq.a.images': 'Alcuni EPUB usano path relativi non standard per le immagini — questo può causare problemi con il protocollo <code>file://</code>. Soluzioni:',
    'faq.a.images.li1': 'Usa il server locale (<code>python -m http.server 8000</code>)',
    'faq.a.images.li2': 'Estrai il capitolo: le immagini vengono convertite in base64 inline e sono sempre visibili nel documento estratto',
    'faq.a.images.li3': 'Usa l\'ePub Slimmer che riscrive i path delle immagini',
    'faq.q.toc': 'La sidebar TOC è vuota',
    'faq.a.toc': 'Alcuni EPUB non includono un file di navigazione (NCX o nav.xhtml). Puoi verificare aprendo la console del browser e controllando <code>book.navigation.toc</code>. Se è vuoto o undefined, il libro non ha TOC e puoi navigare solo con le frecce.',
    'faq.snapshot.label': 'Snapshot',
    'faq.snapshot.h2': 'Domande sugli <em>snapshot</em>',
    'faq.q.persist': 'Gli snapshot vengono mantenuti dopo aver chiuso il browser?',
    'faq.a.persist': 'Sì. Gli snapshot vengono salvati come <strong>file HTML su filesystem locale</strong> tramite la File System Access API del browser. I metadati (nome, data, riferimento al file) sono conservati in <code>noesisDB</code> (IndexedDB). I file rimangono sul disco finché non li elimini esplicitamente dall\'interfaccia Snapshot History o dal filesystem.',
    'faq.q.size': 'Quanto spazio occupano gli snapshot?',
    'faq.a.size': 'Ogni snapshot contiene l\'HTML completo del capitolo (no diff, no compressione). Un capitolo medio con testo e alcune immagini base64 occupa tra 500KB e 5MB per snapshot. Se hai molti snapshot su capitoli con molte immagini, controlla lo spazio in DevTools → Application → Storage. Elimina i snapshot obsoleti dalla Snapshot History.',
    'faq.q.transfer': 'Posso accedere agli snapshot di un altro dispositivo?',
    'faq.a.transfer': 'Non in modo automatico. Gli snapshot sono file HTML sul tuo filesystem locale — non ci sono nuvole né sincronizzazione (per design — privacy totale). Per trasferire il lavoro su un altro dispositivo: copia i file snapshot nella stessa cartella sul nuovo dispositivo, poi importali dall\'interfaccia Snapshot History. Copia anche il file EPUB e il file Noesis.',
    'faq.q.undo': 'Ho caricato uno snapshot per errore — posso annullare?',
    'faq.a.undo': 'Se avevi salvato uno snapshot del tuo lavoro corrente prima di fare Load, puoi semplicemente ricaricare quello snapshot. Se non avevi uno snapshot del lavoro corrente, il ripristino non è annullabile — il contenuto è stato sostituito. <strong>Best practice: salva sempre uno snapshot prima di fare Load su una versione precedente.</strong>',
    'faq.export.label': 'Export e Editor',
    'faq.export.h2': 'Export, PDF e <em>DOCX</em>',
    'faq.q.pdf': 'L\'export PDF non funziona o fallisce',
    'faq.a.pdf': 'In v810, l\'export PDF usa la stampa nativa del browser (<code>window.print()</code>) — non richiede librerie esterne e funziona sempre offline. Se non si apre il dialog di stampa, verifica che i popup non siano bloccati. In alternativa, usa il pulsante <strong>👁 PDF Viewer</strong> per aprire Mozilla PDF.js e stampare da lì. Per DOCX, usa il pulsante DOCX nella toolbar del capitolo estratto.',
    'faq.q.pdfimages': 'Posso esportare le immagini nel PDF?',
    'faq.a.pdfimages': 'Sì. Le immagini nel capitolo estratto sono già convertite in base64 inline. Vengono incluse automaticamente nell\'export PDF e DOCX senza configurazioni aggiuntive. Il documento esportato è completamente autocontenuto.',
    'faq.q.cms': 'Come copio il contenuto dell\'editor nel mio CMS?',
    'faq.a.cms': 'Usa il pulsante <strong>&lt;/&gt; Copia HTML</strong> nella toolbar dell\'editor. Copia tutto l\'HTML del documento negli appunti. In WordPress, passa alla modalità HTML dell\'editor (blocco Codice HTML o editor classico → testo); in Ghost, usa il blocco HTML; in Webflow, incolla in un elemento Rich Text o HTML Embed.',
    'faq.q.docx': 'Il file DOCX si apre male in Word',
    'faq.a.docx': 'Il DOCX generato da Noesis segue il formato OOXML base. Funziona bene in LibreOffice e Google Docs. In Word alcune formattazioni complesse (tabelle annidate, immagini base64 di grandi dimensioni) possono essere interpretate in modo leggermente diverso. Per la compatibilità ottimale con Word, usa la stampa → PDF come formato di consegna finale.',
    'faq.privacy.label': 'Privacy e storage',
    'faq.privacy.h2': 'Dati e <em>privacy</em>',
    'faq.q.data': 'Dove vengono salvati i miei dati?',
    'faq.a.data': 'Tutti i dati di Noesis vengono salvati localmente nel tuo browser. Nessun dato lascia il dispositivo. Lo storage usato:',
    'faq.q.clear': 'Cosa succede se cancello i dati del browser?',
    'faq.a.clear': 'Cancellare i dati del browser (Cancella dati di navigazione → Cookie e file memorizzati nella cache → IndexedDB) rimuove i libri dalla libreria, i metadati dei capitoli estratti e i metadati degli snapshot da noesisDB. <strong>Non elimina i file HTML degli snapshot</strong> che hai salvato sul filesystem — quelli rimangono disponibili per reimportazione. I libri devono essere reimportati dai file EPUB originali.',
    'faq.q.gdpr': 'Noesis è conforme al GDPR?',
    'faq.a.gdpr': 'Sì, completamente. Noesis implementa privacy by design: zero trasmissione di dati a server esterni, zero tracking, zero analytics. Tutti i dati rimangono nel tuo browser e sul tuo dispositivo. Non c\'è nulla da dichiarare o gestire dal punto di vista GDPR perché nessun dato personale viene raccolto o trasmesso.',
    'faq.a.browsers': '<div class="table-wrap" style="margin:0;"><table><thead><tr><th>Browser</th><th>Versione min.</th><th>Stato</th><th>Note</th></tr></thead><tbody><tr><td>Chrome</td><td>90+</td><td><span class="badge badge-green">✓ Completo</span></td><td>Traduzione nativa integrata</td></tr><tr><td>Edge</td><td>90+</td><td><span class="badge badge-green">✓ Completo</span></td><td>Basato su Chromium</td></tr><tr><td>Firefox</td><td>88+</td><td><span class="badge badge-green">✓ Completo</span></td><td>Tutte le funzionalità</td></tr><tr><td>Opera</td><td>76+</td><td><span class="badge badge-green">✓ Completo</span></td><td>Basato su Chromium</td></tr><tr><td>Safari</td><td>14+</td><td><span class="badge badge-gray">⚠ Parziale</span></td><td>IndexedDB con limitazioni storage</td></tr></tbody></table></div>',
    'faq.tech.label': 'Tecnologia',
    'faq.tech.h2': 'API Browser <em>utilizzate</em>',
    'faq.tech.idb.h': '💾 IndexedDB',
    'faq.tech.idb.p': 'Storage persistente per libri (EpubLibraryDB) e capitoli estratti + snapshot (noesisDB). Asincrono, supporta file binari di grandi dimensioni.',
    'faq.tech.clipboard.h': '📋 Clipboard API',
    'faq.tech.clipboard.p': 'Cattura le selezioni di testo per i chunk e copia l\'HTML dell\'editor negli appunti per l\'incolla nel CMS.',
    'faq.tech.canvas.h': '🖼️ Canvas API',
    'faq.tech.canvas.p': 'Usata per la compressione e conversione immagini nell\'ePub Slimmer e nel ridimensionamento immagini dell\'editor. L\'export PDF in v810 usa la stampa nativa del browser, non Canvas.',
    'faq.tech.translation.h': '🌐 Translation API (browser)',
    'faq.tech.translation.p': 'Traduzione integrata nativa del browser (Chrome, Edge, Firefox). Non è una API di Noesis — è una funzionalità del browser che Noesis non controlla.',
    'faq.tech.print.h': '🖨️ Print API',
    'faq.tech.print.p': 'Stampa nativa e salvataggio PDF tramite <code>window.print()</code> con CSS <code>@media print</code> ottimizzati per ogni contesto (reader, capitolo estratto, editor).',
    'faq.tech.filereader.h': '📁 FileReader API',
    'faq.tech.filereader.p': 'Import di file EPUB e immagini dal filesystem dell\'utente. Lettura come ArrayBuffer per JSZip e come base64 per le immagini dell\'editor.',
    'faq.pagenav.prev': '← Helper tools',
    'faq.pagenav.next': 'Note →',

    // NOTES (abbreviated)
    'notes.meta.desc': 'Changelog versioni, problemi noti e consigli d\'uso per Noesis EPUB Reader.',
    'notes.hero.badge': 'Note di versione',
    'notes.hero.h1': 'Changelog, <em>Limiti</em> e Consigli',
    'notes.hero.p': 'Cronologia delle versioni, problemi noti e suggerimenti per usare Noesis al meglio.',
    'notes.changelog.label': 'Changelog',
    'notes.changelog.h2': 'Storia delle <em>versioni</em>',
    'notes.v810.current': 'Corrente',
    'notes.v810.date': 'Marzo 2026',
    'notes.v810.li1': 'Excalidraw integrato nell\'editor — diagrammi, flowchart e mappe mentali in una tab dedicata',
    'notes.v810.li2': 'Export SVG e PNG da Excalidraw, salvati localmente nel browser',
    'notes.v810.li3': 'Extract Chapter — menu a 2 opzioni: "Current chapter only" e "Current + all sublevels"',
    'notes.v810.li4': 'Pandoc Online disponibile nel dropdown Tools della Library — conversioni documento via pandoc.wasm nel browser',
    'notes.v810.li5': 'Help Overlay espanso — Button Reference completo per Library, Reader ed Editor',
    'notes.v810.ch1': 'Snapshot migrati su filesystem locale — file HTML reali scaricati su disco, non più in IndexedDB',
    'notes.v810.ch2': 'noesisDB mantiene solo metadati (ID, nome, timestamp) per popolare la Library',
    'notes.v810.ch3': 'Import Snapshots — reimporta file HTML da disco in noesisDB con un click',
    'notes.v703.date': 'Marzo 2026',
    'notes.v703.li1': 'Sistema Snapshot — salva, carica ed elimina versioni del capitolo estratto',
    'notes.v703.li2': 'noesisDB (IndexedDB) — database dedicato per capitoli estratti e snapshot',
    'notes.v703.li3': 'Libreria gerarchica dark — vista libro → capitoli estratti → snapshot',
    'notes.v686.date': 'Febbraio 2026',
    'notes.v686.li1': 'Editor Summernote Lite completo (sn56.x) sostituisce il precedente editor Quill',
    'notes.v686.li2': 'Tab Excalidraw in tab editor dedicata',
    'notes.v686.li3': 'Sistema raccolta chunk completo: testo, immagini, tabelle',
    'notes.v686.li4': 'Export multi-formato: PDF, DOCX, MD, MD+ZIP, HTML, JSON, TXT',
    'notes.v652.date': 'Gennaio 2026',
    'notes.v652.li1': 'Highlighting a 3 colori con persistenza CFI (giallo, verde, rosa)',
    'notes.v652.li2': 'Estrazione gerarchica capitoli — capitolo corrente + tutti i sottolivelli',
    'notes.v652.li3': 'Segnalibri personalizzati con persistenza localStorage',
    'notes.v652.li4': '15 temi di lettura in 5 gruppi',
    'notes.v646.date': 'Dicembre 2025',
    'notes.v646.li1': 'Versione iniziale — reader EPUB di base con epub.js',
    'notes.v646.li2': 'Libreria IndexedDB (EpubLibraryDB)',
    'notes.v646.li3': 'Toolbar di lettura di base con sidebar TOC',
    'notes.known.label': 'Problemi noti',
    'notes.known.h2': 'Limiti e <em>workaround</em>',
    'notes.issue1.h': 'Android: File System Access API',
    'notes.issue1.p': 'Su alcune versioni Android, la File System Access API per il salvataggio degli snapshot potrebbe chiedere il permesso ad ogni utilizzo. Questo è un limite del browser, non un bug di Noesis. Workaround: usa la versione Desktop per lavori intensivi con snapshot.',
    'notes.issue2.h': 'Safari: limitazioni IndexedDB',
    'notes.issue2.p': 'Safari impone limiti di storage più severi per IndexedDB. EPUB grandi (>50MB) possono fallire l\'importazione. Workaround: usa prima ePub Slimmer per ridurre le dimensioni, oppure passa a Chrome/Firefox.',
    'notes.issue3.h': 'Protocollo file://: restrizioni CORS',
    'notes.issue3.p': 'Aprire Noesis direttamente con il protocollo <code>file://</code> può causare problemi CORS con alcuni EPUB. Workaround: usa un server locale (<code>python -m http.server 8000</code>).',
    'notes.issue4.h': 'DOCX e formattazione Word complessa',
    'notes.issue4.p': 'Il DOCX generato da html-docx-js ha formattazione OOXML di base. Tabelle annidate e immagini molto complesse potrebbero non renderizzare perfettamente in Microsoft Word. Workaround: usa PDF per la consegna, DOCX per la modifica in LibreOffice/Google Docs.',
    'notes.tips.label': 'Pro tips',
    'notes.tips.h2': 'Ottieni il massimo da <em>Noesis</em>',
    'notes.tip1.h': '💡 Workflow tip: snapshot prima di modificare',
    'notes.tip1.p': 'Salva sempre uno snapshot prima di iniziare modifiche importanti o cambiamenti strutturali a un capitolo. L\'investimento di 2 secondi protegge dalla perdita irreversibile di dati.',
    'notes.tip2.h': '💡 Lettura multilingue: gli highlight restano sull\'originale',
    'notes.tip2.p': 'Attiva la traduzione browser prima di leggere un testo straniero. Gli highlight vengono applicati sul testo originale (CFI-based) e rimangono stabili anche passando tra vista originale e tradotta.',
    'notes.tip3.h': '💡 EPUB grandi: riduci prima di importare',
    'notes.tip3.p': 'Se un EPUB ha molte immagini ad alta risoluzione (>20MB), usa ePub Slimmer prima di importare. Riduce significativamente i tempi di caricamento e lo spazio in IndexedDB.',
    'notes.tip4.h': '💡 Export per CMS: usa Copia HTML',
    'notes.tip4.p': 'Per WordPress, Ghost o Webflow, usa il pulsante &lt;/&gt; Copia HTML. L\'HTML è già pulito con immagini base64 inline — incolla direttamente nel blocco HTML del CMS.',
    'notes.license.label': 'Licenza',
    'notes.license.h2': 'MIT License — <em>uso libero</em>',
    'notes.license.p': 'Noesis è software open source distribuito sotto licenza MIT.',
    'notes.license.can.h': '✅ Cosa puoi fare',
    'notes.license.can.p': 'Usare Noesis per qualsiasi scopo (personale o commerciale) · Copiare il file HTML · Modificare il codice · Distribuire con la nota di copyright · Tutto gratuitamente, senza registrazione',
    'notes.license.req.h': '📋 Unico requisito',
    'notes.license.req.p': 'Mantenere la nota di copyright originale nelle copie o distribuzioni sostanziali del software. Per uso personale, non si applica nemmeno questo vincolo.',
    'notes.pagenav.prev': '← FAQ',
    'notes.pagenav.next': 'Approfondimenti →',

    // APPROFONDIMENTI (hub)
    'appro.hero.badge': 'Documentazione tecnica e di progetto',
    'appro.hero.h1': 'Approfondimenti <em>Noesis</em>',
    'appro.hero.p': 'Documentazione completa: architettura, interfaccia, workflow, posizionamento e analisi legale. Testo integrale dei file di progetto.',
    'appro.docs.label': 'Documentazione',
    'appro.docs.h2': 'Documenti <em>tecnici</em>',
    'appro.docs.p': 'Riferimenti completi per l\'interfaccia, l\'architettura e i flussi d\'uso di Noesis.',
    'appro.project.label': 'Progetto',
    'appro.project.h2': 'Documenti di <em>progetto</em>',
    'appro.project.p': 'Posizionamento, analisi legale e presentazione del progetto Noesis.',
  },

