    // ── COMMON ──
    'common.new': 'nouveau',
    'common.current': 'Courant',
    'common.localserver': 'Serveur local recommandé',
    'common.localserver.body': 'Pour une meilleure expérience avec des fichiers EPUB complexes, démarrez un serveur local : <code>python -m http.server 8000</code> dans le dossier extrait et ouvrez <code>http://localhost:8000/noesis810.html</code>',

    // ── DEEPDIVE CALLOUT ──
    'deepdive.callout': '🌐 Cette page d\'approfondissement technique est rédigée en italien. Utilisez la fonction <strong>Traduction</strong> de votre navigateur pour la lire dans votre langue.',

    // ════════════════════════════════════════
