    'appro.docs.label': 'Documentation',
    'appro.docs.h2': 'Documents <em>techniques</em>',
    'appro.docs.p': 'Références complètes pour l\'interface, l\'architecture et les flux d\'utilisation de Noesis.',
    'appro.project.label': 'Projet',
    'appro.project.h2': 'Documents de <em>projet</em>',
