    'guida.callout.multilingual': '<strong>Multilingual workflow</strong>Enable browser translation before reading a foreign text. Highlights remain on the original text, not the translation.',
    'guida.f3.label': 'Phase 3',
    'guida.f3.h2': '✏️ Extract and <em>write</em>',
    'guida.f3.p': 'One click on Extract Chapter opens directly <strong>Noesis Editor</strong> — the unified Summernote editor with the chapter content already loaded.',
